@model DealEngine.WebUI.Models.Authorization.AuthorizeViewModel

<form>
    <!-- Title -->
    <div class="form-group col-12">
        <h3>Delete Role</h3>
    </div>

    <!-- Role Selection -->
    <div class="form-group col-12">
        <label for="DeleteRoleSelect">Select Role to Delete</label>
        <select class="form-select" id="DeleteRoleSelect">
            @foreach (var role in Model.RoleList)
            {
                <option value="@role.Name">@role.Name</option>
            }
        </select>
    </div>

    <!-- Delete Button -->
    <div class="form-group col-12">
        <button type="button" class="btn btn-danger" onclick="confirmRoleDeletion()">Delete Role</button>
    </div>
</form>

<script>
    function confirmRoleDeletion() {
        var selectedRole = $('#DeleteRoleSelect').val();
        confirmDelete('role', selectedRole);
    }
</script>