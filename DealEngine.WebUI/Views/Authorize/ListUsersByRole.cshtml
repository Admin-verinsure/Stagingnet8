@model DealEngine.WebUI.Models.Authorization.AuthorizeViewModel

<form>

    <div class="form-group col-12">
        <label for="RoleSelect">Select Role</label>
        <select class="form-select" id="RoleSelect">
            @foreach (var role in Model.RoleList)  // Assuming Model.Roles contains the list of roles
            {
                <option value="@role">@role</option>
            }
        </select>
    </div>

    <div class="form-group col-12">
        <label>Users with the selected Role:</label>
        <ul id="usersList" class="list-unstyled">
            <!-- Users will be populated here -->
        </ul>
    </div>

</form>