                if ($(this).is(':checked')) {
                    mainOrgId = $(this).attr('id').split('_')[1];
                }
            });


            var rolesToAdd = new Set(); // Using a Set to ensure uniqueness

            // Iterate through each selected organization ID
            selectedOrgs.forEach(function (orgId) {
                // Construct the ID for the corresponding user type dropdown
                var userTypeDropdownId = 'UserType_' + orgId;

                // Select the dropdown and get its value
                var selectedUserTypes = $('#' + userTypeDropdownId).val();

                // Add each selected user type to the set
                rolesToAdd.add(selectedUserType);
            });

            var uniqueRolesToAdd = Array.from(rolesToAdd);



            var oktaUID = $('#OktaUID').val();
            var salespersonUsername = $('#SalespersonUsername').val();
            var employeeNumber = $('#EmployeeNumber').val();
            var password = $('#InputPassword').val();


            // TODO - imrpove on Basic validation
            if (!firstName || !lastName || !email) {
                alert("Please fill in all required fields.");
                return;
            }

            /*
                //var organisationName = $('#Organisation option:selected').text();
                //var isBrokerWithMarsh = userType === 'Broker' && organisationName.includes('Marsh');

