@model IssueUISViewModel

<div class="container">
    <form method="POST" action="~/Home/IssueReminder" novalidate>
        <input type="hidden" name="ProgrammeId" value="@Model.ProgrammeId" />

        <div class="card">
            <div class="card-header">
                <h5>
                    This page lists the clients from this programme. Please select the client and click on Send to issue the information sheet reminder,
                    this will send out the login instruction email and information sheet reminder email.
                    If you cannot find the client in the list, use Create UIS from the previous page to add them.
                </h5>
            </div>

            <div class="card-body">
                <!-- Search box with native datalist autocomplete -->
                <div class="mb-3">
                    <input type="text"
                           id="clientSearch"
                           class="form-control"
                           placeholder="Search clients…"
                           list="clientNames"
                           autocomplete="off" />
                    <datalist id="clientNames">
                        @foreach (var cp in Model.ClientProgrammes)
                        {
                            <option value="@cp.Owner.Name"></option>
                        }
                    </datalist>
                </div>

                <table id="clientTable" class="table">
                    <thead>
                        <tr>
                            <th>
                                <input type="checkbox" id="select-all" aria-label="Select all"> Name
                            </th>
                            <th>Email</th>
                            <th>Reminder Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var clientProg in Model.ClientProgrammes)
                        {
                            <tr>
                                <td>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <div class="input-group-text">
                                                <input type="checkbox"
                                                       name="@clientProg.Owner.Email"
                                                       value="@clientProg.Id" />
                                            </div>
                                        </div>
                                        <input type="text"
                                               class="form-control"
                                               value="@clientProg.Owner.Name"
                                               readonly />
                                    </div>
                                </td>
                                <td>
                                    <input type="text"
                                           class="form-control"
                                           value="@clientProg.Owner.Email"
                                           readonly />
                                </td>
                                <td>
                                    <input type="text"
                                           class="dateInput form-control"
                                           value="@clientProg.ReminderDate"
                                           readonly />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-footer">
                <button class="btn btn-primary btn-xs" type="submit">Send</button>
            </div>
        </div>
    </form>
</div>

@section pagespecific {
    <script>
        $(function(){
          // Select / deselect all checkboxes
          $('#select-all').on('click', function(){
            $('#clientTable tbody input[type="checkbox"]').prop('checked', this.checked);
          });

          // Filter rows as you type, starting at 2 characters
          $('#clientSearch').on('input', function(){
            var term = this.value.trim().toLowerCase();
            if (term.length >= 2) {
              $('#clientTable tbody tr').each(function(){
                var name = $(this)
                  .find('input.form-control[readonly]')
                  .first()
                  .val()
                  .toLowerCase();
                $(this).toggle(name.indexOf(term) !== -1);
              });
            }
            else if (term.length === 0) {
              $('#clientTable tbody tr').show();
            }
          });
        });
    </script>
}
