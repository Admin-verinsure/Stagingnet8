                var Element = document.getElementById(Id);
                if (Element != null) {
                    Element.value = Output[obj][Field];
                }                
            }
        }
    }

    function PopulateOrganisationView(Method, OutPut) {
        debugger;
        try {
            var Form = document.getElementById("organisationViewModel");
            var TradingName = document.getElementById("NoTradingName");
            var DateofIncorporation = document.getElementById("NoDateofIncorportation");
            var Unit = document.getElementsByName("Unit");
            if (TradingName != null) {
                TradingName.value = false;
            }
            if (DateofIncorporation != null) {
                DateofIncorporation.value = false;
            }
            for (obj in OutPut) {
                var model = OutPut[obj];
                var Type = obj;
                for (var Field in model) {
                    var Element = null;
                    var Value = "";

                    if (model.hasOwnProperty("InsuranceAttributes")) {
                        if (Field === "InsuranceAttributes") {
                            var Id = Type + ".InsuranceAttribute";
                            Value = OutPut[obj][Field]["0"]["Name"];
                            if (Value == "Administrator") {
                                Unit = "AdministratorUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            } else if(Value == "Director") {
                                Unit = "DirectorUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            } else if(Value == "Barrister") {
                                Unit = "BarristerUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            }else if(Value == "EBarrister") {
                                Unit = "EBaristerUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            }else if(Value == "JBarrister") {
                                Unit = "JBaristerUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            } else if (Value == "MREDirector") {
                                Unit = "RealEstateDirectorUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            } else if (Value == "Run Off") {
                                Unit = "RealEstateRunOffUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            } else if (Value == "Trustee") {
                                Unit = "Unit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            } else if (Value == "Employee") {
                                Unit = "EmployeeUnit";
                                PopulateOrganisationalUnit(OutPut, Unit);
                            }else {
                                if (Unit.length > 0) {
                                    PopulateOrganisationalUnit(OutPut, Unit[0].id);

                                }
                            }
                            Element = document.getElementById(Id);
                        }
                    }
                   


                    if (model.hasOwnProperty("OrganisationType")) {
                        if (Field === "OrganisationType") {
                            var Id = Type + ".OrganisationType";
                            Value = OutPut[obj][Field]["Name"];
                            Element = document.getElementById(Id);
                        }
                    }

                    if (Element == null) {
                        var Id = Type + "." + Field;
                        Element = document.getElementById(Id);
                        Value = OutPut[obj][Field];
                    }
                    if (Element != null) {
                        if (Element.tagName == "INPUT") {
                            if (Element.type == "date") {
                                //hardcord date string
                                var date = Value.substring(0, 10);
                                if (date == "0001-01-01") {
                                    Element.value = null;
                                } else {
                                    Element.value = date;
                                    //Element.type = "text";
                                }
                            }
                            else {
                                Element.value = Value;
                            }
                        }
                        else if (Element.tagName == "SELECT") {
                            for (var o = 0; o < Element.options.length; o++) {
                                if (Element.options[o].value == Value.toString()) {
                                    Element.options[o].selected = true;
                                    break;
                                }
                            }
                        }
                        OnChange(Element.id, Element.name);
                    }
                    else {
                        //unfound html ids are here
                    }
                }
                if (Method == "Owner") {
                    debugger;
                    // var dropdown = document.getElementById("Organisation.InsuranceAttribute");

                    // if (dropdown) {
                    //      dropdown.selectedIndex = 0; // resets to first option
                    // }
                    if (document.getElementById("Else") != null) { 
                     document.getElementById("Else").hidden = false;
                    }

                    if (document.getElementById("EmailDiv") != null) {
                        document.getElementById("EmailDiv").hidden = false;
                    }


                    TradingNameOwnerOnLoad();

                    var ProgrammeName = document.getElementById("Programme_NamedPartyUnitName");
                    if (ProgrammeName.value == "NZPI Programme") {
                        NZPIOwnerOnLoad();
                    }
                    if (ProgrammeName.value == "Apollo Programme" || ProgrammeName.value == "Apollo ML Programme" ||
                        ProgrammeName.value == "Abbott Financial Advisor Liability Programme") {
                        ApolloOwnerOnLoad();
                    } 

                    if (ProgrammeName.value == "New Zealand Bar Association Liability Programme") {
                        ABusinessOnChange();
                    } 
                    // if (ProgrammeName.value == "Financial Advice NZ Financial Advice Provider Liability Programme") {
                    //     var TradingName = document.getElementById("Organisation.TradingName");
                    //     TradingName.removeAttribute("required");
                    //     TradingName.removeAttribute("is-invalid");
                    //} 
                    var NoTradingNameValidation = document.getElementById("NoTradingNameValidation");
                    var TradingName = document.getElementById("Organisation.TradingName");
                    if (NoTradingNameValidation != null && NoTradingNameValidation.value == "True") {
                        TradingName.classList.remove("is-invalid");
                        TradingName.hidden = false;
                        TradingName.classList.add("is-valid");
                    }
                   
                }
                if (OutPut["User"] == null) {
                    //user is null so we override with organisation
                    document.getElementById("User.Email").value = OutPut["Organisation"]["Email"];
                }

                
            }


                var dropdown = document.getElementById("Organisation.InsuranceAttribute");

    if (dropdown) {

        if (Method == "Owner") {

            // If Administrator is selected, reset selection
            if (dropdown.value === "Administrator") {
                dropdown.selectedIndex = 0;
            }

            // Remove Administrator if exists
            for (var i = 0; i < dropdown.options.length; i++) {
                if (dropdown.options[i].value === "Administrator") {
                    dropdown.remove(i);
                    break;
                }
            }

        } else {

            // Check if Administrator already exists
            var exists = false;
            for (var i = 0; i < dropdown.options.length; i++) {
                if (dropdown.options[i].value === "Administrator") {
                    exists = true;
                    break;
                }
            }

            // If not exists, add it back
            if (!exists) {
                var option = document.createElement("option");
                option.text = "Administrator";
                option.value = "Administrator";

                // Insert after "-- Select --" (index 1)
                dropdown.insertBefore(option, dropdown.options[1]);
            }
        }
    }


        } catch (ex) { debugger; }
    }

    
     function ABusinessOnChange() {
