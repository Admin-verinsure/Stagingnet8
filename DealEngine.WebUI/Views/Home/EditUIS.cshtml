@model IssueUISViewModel

<div class="container mt-4">
    <form method="post" action="~/Home/EditUIS" novalidate>

        <input type="hidden" name="ProgrammeId" value="@Model.ProgrammeId" />

        <div class="card shadow-sm">

            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    Select clients and choose Club / District flags.
                </h5>
            </div>

            <div class="card-body">

                <table class="table table-bordered table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:5%">
                                <input type="checkbox" id="select-all" />
                            </th>
                            <th>Name</th>
                            <th>Email</th>
                            <th class="text-center">IsClub</th>
                            <th class="text-center">IsDistrict</th>
                            <th class="text-center">IsIndependentEntity</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var clientProg in Model.ClientProgrammes)
                        {
                            <tr>
                                <!-- Select client -->
                                <td class="text-center">
                                    <input type="checkbox"
                                           class="client-checkbox"
                                           name="SelectedClientIds"
                                           value="@clientProg.Id" />
                                </td>

                                <!-- Name -->
                                <td>
                                    @clientProg.Owner.Name
                                </td>

                                <!-- Email -->
                                
                                <td>
                                    @clientProg.Owner.Email
                                   
                                </td>
                                
                                <!-- IsClub -->
                                <td class="text-center">
                                    <input type="checkbox"
                                           class="club-checkbox"
                                           name="IsClub_@clientProg.Id" />
                                </td>

                                <!-- IsDistrict -->
                                <td class="text-center">
                                    <input type="checkbox"
                                           class="district-checkbox"
                                           name="IsDistrict_@clientProg.Id" />
                                </td>

                                <!-- IsIndependentEntity -->
                                <td class="text-center">
                                    <input type="checkbox"
                                           name="IsIndependentEntity_@clientProg.Id"
                                           @(clientProg.IsIndependentEntity ? "checked" : "") />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>

            <div class="card-footer text-end">
                <button type="submit" class="btn btn-success">
                    Send
                </button>
            </div>

        </div>
    </form>
</div>

@section pagespecific {
    <script>
        // Select All clients
        document.getElementById("select-all")
            .addEventListener("change", function () {
                let checkboxes = document.querySelectorAll(".client-checkbox");
                checkboxes.forEach(cb => cb.checked = this.checked);
            });
    </script>
}