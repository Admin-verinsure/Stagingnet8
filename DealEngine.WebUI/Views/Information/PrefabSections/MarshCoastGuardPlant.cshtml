@model DealEngine.WebUI.Models.InformationViewModel
<div id="MarshCoastGuardPlantTabs">
    <input id="ClaimId" name="ClaimViewModel.ClaimId" type="hidden" form="ClaimViewModel" />
    @*<input id="OrganisationId" name="ClaimViewModel.OrganisationId" type="hidden" form="ClaimViewModel" />*@
    <input id="ProductId" name="ClientProgramme.BaseProgramme.Products.product.Id" type="hidden" form="ClaimViewModel" />
    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item" id="tab1">
            <a class="nav-link active" href="#omvTabs1" data-bs-toggle="tab" onclick="ResetForm('omvTabs3','omvTabs2', 'ClaimNotification', 'ClaimAddButton', 'AddClearBoat')"> List All </a>
        </li>
        <li class="nav-item" id="tab2">
            <a class="nav-link" href="#omvTabs2" data-bs-toggle="tab"> Edit </a>
        </li>
        <li class="nav-item" id="tab3">
            <a class="nav-link" href="#omvTabs3" data-bs-toggle="tab" onclick="ResetForm('omvTabs3','omvTabs2')"> Add </a>
        </li>
        <li class="nav-item" id="tab4">
            <a class="nav-link" href="#omvTabs4" data-bs-toggle="tab"> List Removed </a>
        </li>

    </ul>
    <div class="tab-content">
        <div id="omvTabs1" class="tab-pane" role="tabpanel">
            <table id="tblMarshCoastGuardPlant"
                   class="table table-striped" width="100%"
                   data-show-columns="true"
                   data-pagination="true"
                   data-search="true"
                   data-show-jump-to="true">
                <thead>
                    <tr>
                        <th data-field="editButton" data-sortable="false"></th>
                        <th data-field="MarshPlantYear" data-sortable="true">Year</th>
                        <th data-field="MarshPlantMake" data-sortable="true">Make</th>
                        <th data-field="MarshPlantModel" data-sortable="true">Model</th>
                        <th data-field="MarshPlanSumInsured" data-sortable="true">Sum Insured</th>
                        <th data-field="deleteButton" data-sortable="false"></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var GetVehicle in Model.ClientInformationSheet.Vehicles.Where(l => l.Removed == false && l.Validated == false).ToList())
                    //Where(l => l.Removed == false && l.validated = false && l.transfered = false).ToList()
                    // @foreach (var claim in Model.ClientInformationSheet.ClaimNotifications.Where(l => l.Removed == false).ToList())
                    {
                        <tr id="@GetVehicle.Id">
                            <td>
                                @*<button class="btn btn-success btn-sm" onclick="EditClaim('@claim.Id', '@claim.ClaimTitle', '@claim.ClaimDescription', '@claim.ClaimReference', '@claim.ClaimPolicyReference', '@claim.ClaimInsurerName', '@claim.ClaimInsuredName', '@claim.Claimant', '@claim.ClaimDateOfLoss', '@claim.ClaimNotifiedDate', '@claim.ClaimEstimateInsuredLiability', '@claim.SelectedClaimProducts', '@claim.SelectedResponsiblePrincipal', '@claim.ClaimNotes', '@claim.ClaimBrokerReference', '@claim.ClaimStatus', '@claim.ClaimInsurerReference', '@claim.ClaimPaid', '@claim.ClaimReserve')">*@
                                <button class="btn btn-success btn-sm" onclick="EditVehicle('@GetVehicle.Id')">
                                    <i class="fa fa-edit"></i>
                                    Edit
                                </button>
                            </td>
                            <td>
                                @GetVehicle.Year
                            </td>
                            <td>
                                @GetVehicle.Model
                            </td>
                            <td>
                                @GetVehicle.GroupSumInsured
                            </td>
                            <td>
                                @*<button onclick="SetClaimRemovedStatus('@claim.Id')" type="button" class=" btn btn-danger btn-sm" id="trash"><span class="fa fa-trash"></span></button>*@
                                <button onclick="RemoveVehicle('@get.Id')" type="button" class=" btn btn-danger btn-sm" id="trash"><span class="fa fa-trash"></span></button>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div id="omvTabs2" class="tab-pane" role="tabpanel">
            <div class="form-group">
                <label>Select a Location from the 'List All' Tab and Click Edit Button</label>
            </div>

        </div>
        <div id="omvTabs3" class="tab-pane" role="tabpanel">

        </div>
        <div id="omvTabs4" class="tab-pane" role="tabpanel">

        </div>
    </div>

</div>