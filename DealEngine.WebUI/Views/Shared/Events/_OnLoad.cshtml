        var IsJBarristerUnit = document.getElementsByClassName("JBaristerUnit");
         var IsEBarristerUnit = document.getElementsByClassName("EBaristerUnit");
         if (IsJBarristerUnit != null) {

              document.querySelectorAll('.JBaristerUnit').forEach(function(el) {
                 el.style.display = 'none';
              });
         }
         if (IsBarristerUnit != null) {
                document.querySelectorAll('.BarristerUnit').forEach(function(el) {
                 el.style.display = 'none';
             });
         }
         if (IsEBarristerUnit != null) {
             document.querySelectorAll('.EBaristerUnit').forEach(function(el) {
                 el.style.display = 'none';
              });

         }
          
    }

