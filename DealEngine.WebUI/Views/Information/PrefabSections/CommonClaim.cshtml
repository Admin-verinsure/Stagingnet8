@model DealEngine.WebUI.Models.InformationViewModel
@*
        form conversion later
        <div id="AddClaimNotification">
        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item" id="tab1">
                <a class="nav-link active" href="#ClaimNotification1" data-toggle="tab" onclick="ResetForm('ClaimNotification3','ClaimNotification2', 'Organisation', 'OrganisationSubmitBtn', 'OrganisationClearButton')"> List All </a>
            </li>
            <li class="nav-item" id="tab2">
                <a class="nav-link" href="#ClaimNotification2" data-toggle="tab"> Edit </a>
