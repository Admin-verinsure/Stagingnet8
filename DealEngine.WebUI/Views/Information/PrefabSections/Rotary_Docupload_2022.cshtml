@model DealEngine.WebUI.Models.InformationViewModel

@{ ViewData["Title"] = "Upload Documents"; }


<div id="content" class="container">
    <!-- Bread crumb is created dynamically -->
    <!-- row -->
   

    @*<div class="row">*@

        @*<div class="jarviswidget jarviswidget-color-blue container-fluid" id="wid-id-2" data-widget-editbutton="true" data-widget-colorbutton="false">*@

            @*<header>
                <span class="widget-icon"> <i class="fa fa-comments text-white"></i> </span>
                <h2> Manage Document </h2>
            </header>*@

            <div class="col-sm-12" style="overflow-y:auto; height:44vh; width:100%;text-align:center;">
                <form id="DocUploadForm" enctype="multipart/form-data" asp-controller="Information" asp-action="Upload" method="post" class="mt-3">


                    @Html.HiddenFor(m => m.ClientProgrammeId)
                    @*@Html.HiddenFor(m => m.AnswerSheetId)*@
                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label">Select Named Party for Document Upload.</label>
                        <div class="col-sm-10">
                            <select asp-for="DocumentOrganisation" class="form-control" required>
                                <option value="select">---Select---</option>
                                @foreach (var option in Model.OrganisationViewModel.Organisations)
                                {
                                    <option value="@option.Name">@option.Name</option>
                                }
                            </select>
                        </div>
                    </div>


                    <div class="form-group row">
                        <label asp-for="Name" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Name" class="form-control" placeholder="Name">
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-sm-2 col-form-label">File</label>
                        <div class="col-sm-10">
                            <div class="custom-file">
                                <input asp-for="File" class="form-control custom-file-input" name="File" id="fileUploaddoc" />

                                @*<input asp-for="File" class="form-control custom-file-input" name="File" type="file" id="fileUploaddoc" />*@
                                @*<label class="custom-file-label" id="custom-file-label">Choose File.../label>*@
                            </div>
                        </div>
                        <div class="col-sm-12 mt-3" style="text-align:center;">
                            <p style="margin:0px !important">Please note: Only .pdf. .doc, .docx, odt and .gdoc file types are accepted.</p>
                        </div>

                    </div>

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <button id="" onclick="" type="submit" class="btn btn-primary">Upload File</button>
                    <br /><br />
                    <br />

                    @foreach (var doc in Model.ClientInformationSheet.documents)
                    {
                        <div class="form-group row">
                            <div class="col-sm-10">
                                <a class="btn btn-primary btn-sm" href="@doc.Path" aria-hidden="true" style="color:white">
                                    @doc.Name
                                </a>
                            </div>
                        </div>
                    }

                </form>
            </div>
        @*</div>*@
    @*</div>*@
</div>




