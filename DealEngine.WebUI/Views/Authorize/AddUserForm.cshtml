@model DealEngine.WebUI.Models.Authorization.AuthorizeViewModel

<form id="addUserForm">
    <div class="form-group col-12">
        <h3>Add New User</h3>
    </div>

    <div class="form-group col-12">
        <label for="InputFirstName">First Name <span style="color: red;">*</span></label>
        <input type="text" class="form-control" id="InputFirstName" placeholder="Enter first name" required>
    </div>

    <div class="form-group col-12">
        <label for="InputLastName">Last Name<span style="color: red;">*</span></label>
        <input type="text" class="form-control" id="InputLastName" placeholder="Enter last name">
    </div>

    <div class="form-group col-12">
        <label for="InputEmail">Email<span style="color: red;">*</span></label>
        <input type="email" class="form-control" id="InputEmail" placeholder="Enter email">
    </div>

    <div class="form-group col-12">
        <label for="InputHomePhone">Home Phone</label>
        <input type="tel" class="form-control" id="InputHomePhone" placeholder="Enter home phone">
    </div>

    <div class="form-group col-12">
        <label for="InputMobilePhone">Mobile Phone</label>
        <input type="tel" class="form-control" id="InputMobilePhone" placeholder="Enter mobile phone">
    </div>


    <!-- User Type Selection -->
    <div class="form-group col-12">
        <label for="UserType">User Type<span style="color: red;">*</span></label>
        <select class="form-control" id="UserType" onchange="toggleBrokerFields()">
            <option value="">Select...</option>
            <option value="Client">Client</option>
            <option value="Broker">Broker</option>
            <option value="Insurer">Insurer</option>
            <option value="Association">Association</option>
        </select>
    </div>

    <!-- Organisation Input -->
    <div class="form-group col-12">
        <label for="Organisation">Organisation<span style="color: red;">*</span></label>
        <select class="form-control" id="Organisation" onchange="toggleBrokerFields()">
            <!-- UC1 Preload to user that is browsing's Organisation -->
            <!-- UC2 TCUser Load all Organisations -->
            @foreach (var org in Model.OrganisationList)
            {
                <option value="@org.Id">@org.Name</option>
            }
        </select>
    </div>

    <div class="form-group col-12" id="brokerFields" style="display: none;">
        <label for="OktaUID">Okta UID<span style="color: red;">*</span></label>
        <input type="text" class="form-control" id="OktaUID" placeholder="Enter Okta UID (e.g 00uixa271s6x7qt8I0h7)">

        <label style="padding-top:15px;" for="SalespersonUsername">Salesperson Username (EGlobal ID) <span class="broker-required" style="color: red; display: none;">*</span></label>
        <input type="text" class="form-control" id="SalespersonUsername" placeholder="Enter Salesperson Username (e.g u1310555)">

        <label style="padding-top:15px;" for="EmployeeNumber">Employee Number <span class="broker-required" style="color: red; display: none;">*</span></label>
        <input type="text" class="form-control" id="EmployeeNumber" placeholder="Enter Employee Number (e.g 1310555)">
    </div>

    <div class="form-group col-12">
        <label for="InputPassword">Password<span style="color: red;">*</span></label>
        <input type="password" class="form-control" id="InputPassword" placeholder="Enter password">
        @if (Model.isMarshUser)
        {
            <small class="form-text text-muted">
                Note: This password will not be your Okta password. It can be used for accessing https://staging.mnzconnect.com (Marsh DealEngine UAT).
            </small>
        }
        <small id="marshNote" class="form-text text-muted" style="display: none;">
            Note: This password will not be your Okta password. It can be used for accessing https://staging.mnzconnect.com (Marsh DealEngine UAT).
        </small>
    </div>

    <div class="form-group col-12 p-2">
        <button type="button" class="btn btn-primary btn-lg" onclick="SaveUser()">Add User</button>
    </div>
</form>
