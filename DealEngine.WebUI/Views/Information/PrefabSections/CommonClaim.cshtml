                            <input class="form-control cl" data-type="TEXTBOX" data-name="ClaimEstimateInsuredLiability" pattern="^\$\d{1,3}(,\d{3})*(\.\d+)?$" id="AddClaimEstimateInsuredLiability" name="ClaimEstimateInsuredLiability" placeholder="$ Estimate of Liability" value="">
