@model DealEngine.WebUI.Models.Authorization.AuthorizeViewModel
<div class="container-fluid">
    <div class="row">
        <div class="accordion container" id="accordionExample">
            <div class="accordion-item">
                <div class="card">
                    <div class="card-header" id="headingOne">
                        <h2 class="mb-0 accordion-header">
                            <button class="btn btn-link " type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                Manage Roles
                            </button>
                        </h2>
                    </div>
                    <div id="collapseOne" class="accordion-collapse collapse" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                        <div class="card-body">

                            <ul class="nav nav-tabs" id="roleTabs" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active" id="add-role-tab" data-bs-toggle="tab" href="#addRole" role="tab" aria-controls="addRole" aria-selected="true">Add Role</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" id="update-role-tab" data-bs-toggle="tab" href="#updateRole" role="tab" aria-controls="updateRole" aria-selected="false">Update Role</a>
                                </li>
                                @if (Model.IsTCUser)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" id="delete-role-tab" data-bs-toggle="tab" href="#deleteRole" role="tab" aria-controls="deleteRole" aria-selected="false">Delete Role</a>
                                    </li>
                                }
                            </ul>

                            <div class="tab-content" id="roleTabsContent">
                                <div class="tab-pane fade show active" id="addRole" role="tabpanel" aria-labelledby="add-role-tab">
                                    <div class="container" id="AddRoleForm">
                                        @await Html.PartialAsync("AddRoleForm", Model)
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="updateRole" role="tabpanel" aria-labelledby="update-role-tab">
                                    <div class="container" id="UpdateRoleForm">
                                        @await Html.PartialAsync("UpdateRoleForm", Model)
                                    </div>
                                </div>
                                @if (Model.IsTCUser)
                                {
                                    <div class="tab-pane fade" id="deleteRole" role="tabpanel" aria-labelledby="delete-role-tab">
                                        <div class="container" id="DeleteRoleForm">
                                            @await Html.PartialAsync("DeleteRoleForm", Model)
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header" id="headingtwo">
                        <h2 class="mb-0 accordion-header">
                            <button class="btn btn-link " type="button" data-bs-toggle="collapse" data-bs-target="#collapsetwo" aria-expanded="false" aria-controls="collapsetwo">
                                Manage Claims
                            </button>
                        </h2>
                    </div>
                    <div id="collapsetwo" class="accordion-collapse collapse" aria-labelledby="headingtwo" data-bs-parent="#accordionExample">
                        <div class="card-body">

                            <ul class="nav nav-tabs" id="claimTabs" role="tablist">
                                <li class="nav-item">
                                    <a class="nav-link active" id="add-claim-tab" data-bs-toggle="tab" href="#addClaim" role="tab" aria-controls="addClaim" aria-selected="true">Add Claim</a>
                                </li>
                                @if (Model.IsTCUser)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" id="delete-claim-tab" data-bs-toggle="tab" href="#deleteClaim" role="tab" aria-controls="deleteClaim" aria-selected="false">Delete Claim</a>
                                    </li>
                                }
                            </ul>

                            <div class="tab-content" id="claimTabsContent">
                                <div class="tab-pane fade show active" id="addClaim" role="tabpanel" aria-labelledby="add-claim-tab">
                                    <div class="container" id="AddClaimForm">
                                        @await Html.PartialAsync("AddClaimForm", Model)
                                    </div>
                                </div>
                                @if (Model.IsTCUser)
                                {
                                    <div class="tab-pane fade" id="deleteClaim" role="tabpanel" aria-labelledby="delete-claim-tab">
                                        <div class="container" id="DeleteClaimForm">
                                            @await Html.PartialAsync("DeleteClaimForm", Model)
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                </div>

                <div class="card">
                    <div class="card-header">
                        <h2 class="mb-0 accordion-header">
                            <button class="btn btn-link" type="button" data-bs-toggle="collapse" data-bs-target="#collapsethree" aria-expanded="false" aria-controls="collapsethree">
                                Manage User Roles
                            </button>
                        </h2>
                    </div>
                    <div id="collapsethree" class="accordion-collapse collapse" aria-labelledby="headingthree" data-bs-parent="#accordionExample">
                        <div class="card-body">
                            <!-- Nav Tabs and Search Form -->
                            <nav class="navbar navbar-expand-lg navbar-light bg-light">
                                <div class="container-fluid">
                                    <ul class="nav nav-tabs" id="manageRolesTabs" role="tablist">
                                        <li class="nav-item">
                                            <a class="nav-link active" id="list-users-role-tab" data-bs-toggle="tab" href="#listUsersRole" role="tab" aria-controls="listUsersRole" aria-selected="true">List Users by Role</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" id="add-role-user-tab" data-bs-toggle="tab" href="#addRoleUser" role="tab" aria-controls="addRoleUser" aria-selected="false">Add Role to User</a>
                                        </li>
                                        @if (Model.IsTCUser)
                                        {
                                            <li class="nav-item">
                                                <a class="nav-link" id="remove-role-user-tab" data-bs-toggle="tab" href="#removeRoleUser" role="tab" aria-controls="removeRoleUser" aria-selected="false">Remove Role from User</a>
                                            </li>
                                        }
                                    </ul>
                                    <form class="d-flex" id="searchForm">
                                        <input class="form-control me-2" type="search" placeholder="Search by Last Name" aria-label="Search" id="lastName" name="lastName">
                                        <button class="btn btn-outline-success" type="button" onclick="searchUser()">Search</button>
                                    </form>
                                </div>
                            </nav>

                            <!-- Tab Content -->
                            <div class="tab-content" id="roleTabsContent">
                                <div class="tab-pane fade show active" id="listUsersRole" role="tabpanel" aria-labelledby="list-users-role-tab">
                                    <!-- List Users By Role Form -->
                                    <div class="container" id="ListUsersByRoleForm">
                                        @await Html.PartialAsync("ListUsersByRole", Model)
                                    </div>
                                </div>
                                <div class="tab-pane fade" id="addRoleUser" role="tabpanel" aria-labelledby="add-role-user-tab">
                                    <!-- Add Role to User Form -->
                                    <div class="container" id="AddRoleToUserForm">
                                        @await Html.PartialAsync("AddRoleToUserForm", Model)
                                    </div>
                                </div>
                                @if (Model.IsTCUser)
                                {
                                    <div class="tab-pane fade" id="removeRoleUser" role="tabpanel" aria-labelledby="remove-role-user-tab">
                                        <!-- Remove Role from User Form -->
                                        <div class="container" id="RemoveRoleUserForm">
                                            @await Html.PartialAsync("RemoveRoleUserForm", Model)
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mt-3" id="usersDetailsContainer">
                                <!-- User details cards will be appended here -->
                            </div>

                        </div>
                    </div>
                </div>

                @* Hidden Add Claims to User Page Section
                    <div class="card">
                        <div class="card-header" id="headingThree">
                            <h2 class="mb-0 accordion-header">
                                <button class="btn btn-link" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                    Add Claims to User
                                </button>
                            </h2>
                        </div>
                        <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree" data-bs-parent="#accordionExample">

                            <div class="card-body">
                                <form id="userclaimform">
                                    <div class="form-group">
                                        <select class="form-select" id="AddClaimUser" data-placeholder="Select User">
                                            @foreach (var user in Model.UserList)
                                            {
                                                <option value="@user.Id">@user.UserName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <select class="cselect form-select" data-placeholder="Add Claims" id="AddUserClaims" multiple="multiple" name="@Html.NameFor(m => m.ClaimList)">
                                            @foreach (var claim in Model.ClaimList)
                                            {
                                                <option value="@claim.Value">@claim.Value</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <button type="button" class="btn btn-primary btn-sm" onclick="SaveClaimToUser()">Save</button>
                                    </div>
                                </form>
                            </div>

                        </div>
                    </div>
                *@
            </div>
        </div>
    </div>
</div>


@section pagespecific {
    <script type="text/javascript">

        var roleClaimsDictionary = @Html.Raw(Json.Serialize(Model.RoleClaims));

        // Manage Roles

        $(document).ready(function () {
            $('#UpdateRoleSelect').on('change', function () {
                var selectedRole = $(this).val();
                showClaimsForRole(selectedRole);
                populateClaimsCheckboxesForRole(selectedRole);
            });
        });

        function showClaimsForRole(role) {
            debugger;

            var claims = roleClaimsDictionary[role] || [];

            var claimsList = $('#roleClaimsList');
            claimsList.empty(); // Clear the list

            claims.forEach(function (claim) {
                var checkboxItem = $('<div class="claim-item" style="width: 50%;"><input type="checkbox" id="CurrentRoleClaim_' + claim + '" name="currentRoleClaims" value="' + claim + '"><label for="CurrentRoleClaim_' + claim + '">' + claim + '</label></div>');

                claimsList.append(checkboxItem);
            });
        }

        function populateClaimsCheckboxesForRole(roleName) {
            var associatedClaims = roleClaimsDictionary[roleName] || [];
            var allClaims = @Html.Raw(Json.Serialize(Model.ClaimList.Select(c => c.Value)));
            var availableClaims = allClaims.filter(claim => !associatedClaims.includes(claim));

            var claimsContainerBox = $('#claims-container-box');
            claimsContainerBox.empty();

            availableClaims.forEach(function (claim) {
                var checkboxItem = $('<div class="claim-item"><input type="checkbox" id="' + claim + '" name="selectedClaims" value="' + claim + '"><label for="' + claim + '">' + claim + '</label></div>');
                claimsContainerBox.append(checkboxItem);
            });
        }

        function getAddedClaims() {
            return $("input[name='selectedClaims']:checked").map(function () {
                return $(this).val();
            }).get();
        }

        function getRemovedClaims() {
            return $("input[name='currentRoleClaims']:checked").map(function () {
                return $(this).val();
            }).get();
        }

        function UpdateRole() {
            var roleName = $('#UpdateRoleSelect').val();
            var claimsToAdd = getAddedClaims();
            var claimsToRemove = getRemovedClaims();

            var postData = {
                RoleName: roleName,
                ClaimsToAdd: claimsToAdd,
                ClaimsToRemove: claimsToRemove
            };
            
            $.ajax({
                url: '@Url.Action("UpdateRole", "Authorize")',
                type: "POST",
                data: postData
            })
                .done(function (data) {
                    location.reload();
                    $('#Success').alert();
                })
                .fail(function (a, s, d) {
                    alert("Unable to save.");
                });
        }

        function SaveRole() {
            var roleName = $('#InputRoleName').val();
            var claim = $('#AddRoleClaims').val();
            var organisationId = $('#organisationId').val();
            var postData = { RoleName: roleName, Claims: claim, OrganisationId: organisationId }

            $.ajax({
                url: '@Url.Action("AddRole", "Authorize")',
                type: "POST",
                data: postData
            })
                .done(function (data) {
                    $('#AddRoleForm').hide();
                    location.reload();
                    $('#Success').alert();
                })
                .fail(function (a, s, d) {
                    alert("Unable to save.");
                });
        }

        function DeleteRole() {
            var e = document.getElementById("DeleteRoleSelect");
            var roleName = e.options[e.selectedIndex].text;
            debugger;
            var postData = { RoleName: roleName }
            $.ajax({
                url: '@Url.Action("DeleteRoleSelect", "Authorize")',
                type: "POST",
                data: postData
            })
                .done(function (data) {
                    location.reload();
                    $('#Success').alert();
                })
                .fail(function (a, s, d) {
                    alert("Unable to save.");
                });
        }

        // Manage Claims

        function SaveClaim() {
            var claimName = $('#newClaimName').val();

            // Check if the claimName is not empty
            if (!claimName) {
                alert("Please enter a claim name.");
                return;
            }

            var postData = {
                claimType: claimName,
                claimValue: claimName
            };

            $.ajax({
                url: '@Url.Action("CreateClaim", "Authorize")',
                type: "POST",
                data: postData
            })
                .done(function (data) {
                    if (data.success) {
                        alert("Claim added successfully!");
                        location.reload();
                    } else {
                        alert("Error adding claim: " + data.message);
                    }
                })
                .fail(function (a, s, d) {
                    alert("Unable to save.");
                });
        }

        function DeleteClaim() {
            var selectedClaimValue = $('#DeleteClaimSelect').val();

            if (!selectedClaimValue) {
                alert('Please select a claim to delete.');
                return;
            }

            if (!confirm('Are you sure you want to delete this claim? This action cannot be undone.')) {
                return;
            }

            $.ajax({
                url: '/Authorize/DeleteClaim', // Update this URL if it's different
                type: 'POST',
                data: {
                    claimValue: selectedClaimValue
                },
                success: function (response) {
                    if (response.success) {
                        alert('Claim deleted successfully.');
                        location.reload(); // Reload the page to reflect the changes
                    } else {
                        alert('Error deleting claim: ' + response.message);
                    }
                },
                error: function () {
                    alert('An error occurred while trying to delete the claim.');
                }
            });
        }

        // List Users By Role

        $(document).ready(function () {
            $('#RoleSelect').on('change', function () {
                var selectedRole = $(this).val();
                fetchUsersForRole(selectedRole);
            });
        });

        function fetchUsersForRole(role) {
            debugger;
            $.ajax({
                url: '@Url.Action("GetUsersByRole", "Authorize")',
                type: "GET",
                data: { roleName: role }
            })
                .done(function (data) {
                    debugger;
                    var usersList = $('#usersList');
                    usersList.empty(); // Clear the list

                    data.forEach(function (user) {
                        var listItem = $('<li data-user-id="' + user.id + '">Username: ' + user.userName + ', Email: ' + user.email + '</li>');
                        usersList.append(listItem);
                    });
                })
                .fail(function () {
                    alert("Unable to fetch users.");
                });
        }

        // Add Role to User

        function SaveRoleToUser() {
            var userId = $('#AddUser').val();
            var roleIds = $('#AddUserRoleSelect').val();
            var postData = { UserId: userId, RoleIds: roleIds }

            $.ajax({
                url: '@Url.Action("SaveRoleToUser", "Authorize")',
                type: "POST",
                data: postData
            })
                .done(function (data) {
                    location.reload();
                    $('#Success').alert();
                })
                .fail(function (a, s, d) {
                    alert("Unable to save.");
                });
        }

        function RemoveRoleFromUser() {
            var userId = $('#RemoveUser').val();
            var roleIds = $('#RemoveUserRoleSelect').val();
            var postData = { UserId: userId, RoleIds: roleIds }

            $.ajax({
                url: '@Url.Action("RemoveRoleFromUser", "Authorize")',
                type: "POST",
                traditional: true,
                data: postData
            })
                .done(function (data) {
                    location.reload();
                    $('#Success').alert();
                })
                .fail(function (a, s, d) {
                    alert("Unable to save.");
                });
        }

        function searchUser() {
            var lastName = $('#lastName').val();
            $.ajax({
                url: '/Authorize/GetUserDetailsByLastName',
                type: 'GET',
                data: { lastName: lastName },
                success: function (data) {
                    if (data && data.length > 0) {
                        $('#usersDetailsContainer').empty(); // Clear previous search results
                        var firstUserId = null;
                        data.forEach(function (user, index) {
                            if (index === 0) {
                                firstUserId = user.id; // Store the ID of the first user
                            }
                            var userCard = `
                                <div class="card mt-3">
                                    <div class="card-header">
                                        User Details
                                    </div>
                                    <ul class="list-group list-group-flush">
                                        <li class="list-group-item"><strong>Username:</strong> ${user.userName}</li>
                                        <li class="list-group-item"><strong>First Name:</strong> ${user.firstName}</li>
                                        <li class="list-group-item"><strong>Last Name:</strong> ${user.lastName}</li>
                                        <li class="list-group-item"><strong>Email:</strong> ${user.email}</li>
                                        <li class="list-group-item"><strong>Roles:</strong> ${user.roles.join(', ')}</li>
                                    </ul>
                                </div>
                            `;
                            $('#usersDetailsContainer').append(userCard);
                        });

                        // Set the selected user in the dropdowns
                        if (firstUserId !== null) {
                            $('#AddUser').val(firstUserId);
                            $('#RemoveUser').val(firstUserId);
                        }
                    } else {
                        alert('No user found with that last name');
                    }
                },
                error: function () {
                    alert('Failed to load user details');
                }
            });
        }

        // Add Claim to User - Deprecated function

        // function SaveClaimToUser() {
        //     var userId = document.getElementById('AddClaimUser').value;
        //     var claims = $('#AddUserClaims').val();
        //     postData = { UserId: userId, Claims: claims }
        //     $.ajax({
        //         url: 'ATUrl.Action("CreateUserToClaim", "Authorize")',
        //         type: "POST",
        //         data: postData
        //     })
        //         .done(function (data) {
        //             $('#Success').alert();
        //             location.reload();
        //         })
        //         .fail(function (a, s, d) {
        //             debugger;
        //             alert("Unable to save.");
        //         });
        // }

    </script>
}

@section PageStyles {
    <style>
        .claims-container {
            display: flex;
            flex-wrap: wrap;
        }

        .claim-item {
            width: 50%;
            box-sizing: border-box;
        }
    </style>
}