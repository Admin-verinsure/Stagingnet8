@model DealEngine.WebUI.Models.Authorization.AuthorizeViewModel

<ul class="nav nav-tabs" id="manageRolesTabs" role="tablist">
    <li class="nav-item">
        <a class="nav-link active" id="list-users-role-tab" data-bs-toggle="tab" href="#listUsersRole" role="tab" aria-controls="listUsersRole" aria-selected="true">List Users by Role</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="add-role-user-tab" data-bs-toggle="tab" href="#addRoleUser" role="tab" aria-controls="addRoleUser" aria-selected="false">Add Role to User</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="remove-role-user-tab" data-bs-toggle="tab" href="#removeRoleUser" role="tab" aria-controls="removeRoleUser" aria-selected="false">Remove Role from User</a>
    </li>
</ul>

<div class="tab-content" id="roleTabsContent">
    <div class="tab-pane fade show active" id="listUsersRole" role="tabpanel" aria-labelledby="list-users-role-tab">
        <!-- List Users By Role Form -->
        <div class="container" id="ListUsersByRoleForm">
            @await Html.PartialAsync("ListUsersByRole", Model)
        </div>
    </div>
    <div class="tab-pane fade" id="addRoleUser" role="tabpanel" aria-labelledby="add-role-user-tab">
        <!-- Add Role to User Form -->
        <div class="container" id="AddRoleToUserForm">
            @await Html.PartialAsync("AddRoleToUserForm", Model)
        </div>
    </div>
    <div class="tab-pane fade" id="removeRoleUser" role="tabpanel" aria-labelledby="remove-role-user-tab">
        <!-- Remove Role from User Form -->
        <div class="container" id="RemoveRoleUserForm">
            @await Html.PartialAsync("RemoveRoleUserForm", Model)
        </div>
    </div>
</div>
 