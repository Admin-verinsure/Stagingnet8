    function PopulateOrganisationalUnit(OutPut, UnitName) {
        debugger;
        for (var Unit in OutPut["Organisation"]["OrganisationalUnits"]) {
            for (var Item in OutPut["Organisation"]["OrganisationalUnits"][Unit]) {
                id = UnitName + "." + Item;
                var element = document.getElementById(id);
                if (element != null) {
                    var Value = OutPut["Organisation"]["OrganisationalUnits"][Unit][Item];
                    if (element.tagName == "INPUT") {
                        if (element.type == "date") {
                            //hardcord date string
                            var date = Value.substring(0, 10);
                            if (date == "0001-01-01") {
                                  element.value = null;
                                } else {
                                  element.value = date;
                                }
                            //element.value = date;
                        }
                        else {
                            element.value = Value;
                        }
                    }
                    else if (element.tagName == "SELECT") {
                        if (element.multiple) {
                            for (var i = 0; i < Value.length; i++) {
                                for (var o = 0; o < element.options.length; o++) {
                                    if (element.options[o].value == Value[i].toString()) {
                                        element.options[o].selected = true;
                                        $(".chosen-select").trigger('chosen:updated');
                                    }
                                }
                            }
                        } else {
                            if (Value == "1") {
                                Value = "true"
                            }
                            else if (Value == "2") {
                                Value = "false";
                            }
                            for (var o = 0; o < element.options.length; o++) {
                                if (element.options[o].value == Value.toString()) {
                                    element.options[o].selected = true;
                                    break;
                                }
                            }
                        }
                    }
                    OnChange(element.id, element.name);
                }
            }
        }
    }


     function applyClientProgrammeRestrictions() {
         debugger;
           let isClub = document.getElementById("IsClubFlag")?.value;
        let isDistrict = document.getElementById("IsDistrictFlag")?.value;
        let isIndependent = document.getElementById("IsIndependentFlag")?.value;



        let dropdown = document.getElementById("Organisation.InsuranceAttribute");

        if (!dropdown) return;

        // Enable everything first
        for (let i = 0; i < dropdown.options.length; i++) {
            dropdown.options[i].disabled = false;
        }

        function disable(values) {
            for (let i = 0; i < dropdown.options.length; i++) {
                if (values.includes(dropdown.options[i].value)) {
                    dropdown.options[i].disabled = true;
                }
            }
        }

        if (isClub === "true") {
            disable([
                "RotaryDistrict",
                "RotarySpecialPurposeTrust",
                "RotaryMultiDistrictOrganisation",
                "RotaryRIActionGroup",
                "RotaryRIFellowshipGroup"
            ]);
        }

        if (isDistrict === "true") {
            disable([
                "RotaryClub",
                "Rotaract",
                "RotaryCommunityCorps",
                "RotaryClubTrustOneOnly",
                "RotaryMultiDistrictOrganisation",
                "RotarySpecialPurposeTrust",
                "RotaryRIActionGroup",
                "RotaryRIFellowshipGroup"
            ]);
        }

        if (isIndependent === "true") {
            disable([
                "RotaryClub",
                "RotaryDistrict",
                "Rotaract",
                "RotaryCommunityCorps",
                "RotaryClubTrustOneOnly",
                "RotaryRIActionGroup",
                "RotaryRIFellowshipGroup"
            ]);
        }

         // Reset invalid selection
         let selected = dropdown.options[dropdown.selectedIndex];
         if (selected && selected.disabled) {
          dropdown.value = "0";
         }
     }



