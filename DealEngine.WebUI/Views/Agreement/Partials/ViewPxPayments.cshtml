@model DealEngine.WebUI.Models.Agreement.ViewAgreementViewModel


@{
    var totalPremiums = Model.TotalPremium.Substring(1);
    var premiumsGSTBrokerFeeCC = 0d;
    var brokerageFee = Model.TotalAdministrationFee.Substring(1);
    var premiumsGSTBrokerFeeInv = 0d;

    //foreach (var item in Model.RiskPremiums)
    //{
    //    //var premium = item.TotalPremium.Replace("$", "");
    //    var premium = item.TotalPremium.Substring(1);
    //    totalPremiums += double.Parse(premium);
    //}
    //premiumsGSTBrokerFee = Math.Round((double.Parse(brokerageFee) + totalPremiums) * (1.15f) * (1.015f), 2);
    premiumsGSTBrokerFeeCC = Math.Round((double.Parse(brokerageFee) + double.Parse(totalPremiums)) * (1.15f) * (1.015f), 2);
    premiumsGSTBrokerFeeInv = Math.Round((double.Parse(brokerageFee) + double.Parse(totalPremiums)) * (1.15f), 2);

}

  <div class="container" id="pxpaycontainer">
        <label class="radio">
           @if (Model.HasCCPayment)
           {
                <input id="paymentCreditCard" name="paymentRadio" type="radio">
                <i></i><strong>
                    Credit Card -- $@premiumsGSTBrokerFeeCC including GST
                </strong>
                <p>Payment by credit card will incur a 1.5% (1.3% + GST) surcharge which will be included on your invoice.</p>
                <p>The total amount to be charged to your credit card will be $@premiumsGSTBrokerFeeInv + 1.5 % surcharge</p>
                <p>Payment can be made by Visa or MasterCard.</p>
                <br />
           
           }
         
            
        </label>

    @if (Model.HasInvoicePayment)
    {
        <input id="paymentEGlobal" name="paymentRadio" type="radio">

        <div id="invoiceModal" class="modal-overlay">
            <div class="modal-box">
                <h4>Information</h4>

                <p>
                    Thank you for submitting this InfoSheet.<br />
                    No payment is required at this stage.<br /><br />
                    The next step will be when the renewal is confirmed.
                    At that point you will receive an email advising the
                    Certificate of Insurance has been released.
                </p>

                <div class="modal-actions">
                    @* <button type="button"
                            class="btn btn-success"
                            onclick="submitPayment()">
                        OK
                    </button> *@


                    <a class="btn btn-primary btn-xs"
                       href="#"
                       onclick="location.href='/Agreement/RenderDocuments?id=' +
                    document.getElementById('AnswerSheetId').value; return false;">
                        <i class="fa fa-random"></i> Back to Client
                    </a>



@* 
                    <button id="NextNoPayment" onclick="bypassPayment()" class="btn btn-primary">Next</button>

 *@
                    <button type="button"
                            class="btn btn-danger"
                            onclick="closeInvoiceModal()">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    }



  </div>




<script type="text/javascript">

    // hide next button immediately
    var nextbutton1 = document.getElementsByClassName("sw-btn-next");
    $(nextbutton1).addClass("hidden").hide();
        var hasInvoicePayment = @(Model.HasInvoicePayment ? "true" : "false");
     // SmartWizard / partial-safe auto show
    setTimeout(function () {
        if (hasInvoicePayment === true) {
            var modal = document.getElementById("invoiceModal");
            if (modal) {
                modal.style.display = "flex";
            }
        }
    }, 200); // small delay fixes wizard rendering

    function confirmInvoicePayment() {
        document.getElementById("invoiceModal").style.display = "none";
           var radio = document.getElementById("paymentEGlobal");
        if (radio) {
            radio.checked = true;
        }

        submitPayment();
    }

    function closeInvoiceModal() {
        document.getElementById("invoiceModal").style.display = "none";
    }

</script>


<style>
    #pxpaycontainer {
        margin-left: 0 !important;
    }

    .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.45);
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .modal-box {
        background: #fff;
        padding: 22px;
        border-radius: 8px;
        width: 420px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

    .modal-actions {
        text-align: right;
        margin-top: 18px;
    }

        .modal-actions .btn {
            margin-left: 8px;
        }
</style>
