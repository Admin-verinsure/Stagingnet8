@model DealEngine.WebUI.Models.InformationViewModel

<div class="padding-10">
    <div id="proposalcreate-form" class="smart-form" novalidate="novalidate">
        <div id="Boattabs">
            <ul id="tab" class="nav nav-tabs">
                <li class="nav nav-tabs active"> <a href="#boatTabs1"> List All </a> </li>
                <li class="nav nav-tabs EditButton hidden" id="EditBoat"> <a href="#boatTabs2"> Edit </a> </li>
                <li class="nav nav-tabs AddButton"> <a href="#boatTabs3"> Add </a> </li>
                <li class="nav nav-tabs BoatRemoved"> <a href="#boatTabs4"> List Removed </a> </li>
            </ul>
            <div id="boatTabs1" class="tab-content">
                <fieldset>
                    <div class="row">
                        <section class="col col-xs-12">
                            <script type="text/javascript">
                                $(window).on('load',function () {
                                    $("#tblBoat").jqGrid({
                                    url: "/Services/GetBoats?informationId=@Model.AnswerSheetId&validated=true&removed=false&transfered=false",
                                    datatype: "xml",
                                        mytpe: "GET",
                                    async: true,
                                    colNames: ["Edit Vessel", "Boat Name", "Year", "Sum Insured", "Delete Vessel"],
                                    colModel: [
                                        {
                                            name: "edit", template: "actions", width: 90, align: 'center', search: false, editable: true, formatter: function (cellvalue, options, rowobject) {
                                                return ('<button onclick="UnhideEdit(\'EditBoat\');EditBoat(\'b\', \'' + cellvalue + '\'); SetCurrentTab(\'boatTabs2\');" type="button" class="btn btn-success btn-sm" >Edit <i class="fa fa-edit"> </i></button>')
                                            }
                                        },
                                        { name: "BoatName", align: 'center', key: 'true', editable: true },
                                        { name: "YearOfManufacture", align: 'center', editable: true },
                                        { name: "MaxSumInsured", align: 'center', editable: true },
                                        {
                                            name: "update", align: 'center', search: false,width:90, editable: true, formatter: function (cellvalue, options, rowobject) {
                                                return ('<button id="trash" onclick="RemoveBoat(\'' + cellvalue + '\', \'true\', \'#tblBoat\', \'#tblRemovedBoat\',\'@Model.ClientInformationSheet.Status\');" type="button" class=" btn btn-danger btn-sm" ><span class="fa fa-trash" id="span"></span></button>');
                                            }
                                        }
                                    ],
                                    autowidth: true,
                                    pager: "#pagerBoat",
                                    rowNum: 10,
                                    rowList: [10, 20, 30],
                                    sortname: "BoatName",
                                    sortorder: "desc",
                                    viewrecords: true,
                                    gridview: true,
                                    autoencode: true,
                                    onSelectRow: function (rowid) {
                                        var grid = $('#tblBoat');
                                        var myCellData = grid.jqGrid('getCell', rowid, 'column_name');
                                        SetCurrentTab("boatTabs-2");
                                    }
                                });
                                $("#tblBoat").jqGrid('navGrid',
                                    '#pagerBoat',
                                    { edit: false, add: false, del: false },
                                    { height: 280, reloadAfterSubmit: false },
                                    { height: 280, reloadAfterSubmit: false },
                                    { reloadAfterSubmit: false },
                                    {search: true},
                                    { sopt: ['eq', 'bw', 'cn'] }
                                );
                            });
                            </script>
                            <table id="tblBoat"><tr><td></td></tr></table>
                            <div id="pagerBoat"></div>
                        </section>
                    </div>
                </fieldset>
            </div>
            <div id="boatTabs2" class="tab-content">
                <fieldset id="fieldset">
                    <form data-bs-toggle="validator" role="form" id="boatForm">
                        <input id="BoatId" class="b" name="BoatId" type="hidden">
                        <input id="openModal" class="b" name="openModal" type="hidden">
                        <div class="row">
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Vessel Name</label>
                                <label class="input form-group col-12">
                                    <i></i>
                                    <input class="form-control b " type="text" data-type="TEXTBOX" data-name="BoatName" id="BoatName" name="BoatName" placeholder="Vessel Name" value="" required>
                                </label>
                                <p class="validationContainer" id="validateBoatName"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Vessel Type</label>
                                <label class="input form-group col-12">
                                    <select onchange="vesselType1Selected()" class="form-control b form-select" id="BoatType1" name="BoatType1" title="" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="Powerboats">Powerboats</option>
                                        <option value="CruisersandLaunches">Cruisers and Launches</option>
                                        <option value="YachtsandCatamarans">Yachts and Catamarans</option>
                                        <option value="Jetski" id="BoatType1Jetski">Jetski</option>
                                        <option value="Jetboat">Jetboat</option>
                                        <option value="Other">Other Personal Watercraft</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateBoatType"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Vessel status when not in use</label>
                                <label class="input form-group col-12">
                                    <select onchange="vesselType2Selected()" class="form-control b form-select" id="BoatType2" name="BoatType2" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="Roadtrailer">Road Trailer</option>
                                        <option value="Stored">Stored</option>
                                        <option id="BoatType2Berthed" value="Berthed">Berthed</option>
                                        <option id="BoatType2Moored" value="Moored">Moored</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateBoatType2"></p>
                            </section>
                            <section class="col col-xs-1 col-sm-1 col-md-1 col-lg-1">
                                <i id="elem" href="#"
                                   class="fa fa-question-circle cgpopover"
                                   data-bs-placement="bottom"
                                   data-bs-container="body"
                                   data-bs-toggle="popover"
                                   data-bs-content="Please select the option that best represents the status of the vessel when it is not being used"></i>
                            </section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Vessel Skipper</label>
                                <label class="input form-group col-12">
                                    <select onchange="addNewSkipper()" class="form-control b form-select" id="BoatOperator" name="BoatOperator" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="@Model.ClientInformationSheet.Owner.Id">@Model.ClientInformationSheet.Owner.Name</option>
                                        @foreach (var skipper in Model.OrganisationViewModel.Organisations.Where(o => o.InsuranceAttributes.Any(i => i.Name == "Skipper")).ToList())
                                        {
                                            if (Model.ClientInformationSheet.Owner.Id != skipper.Id)
                                            {
                                                <option value="@skipper.Id">@skipper.Name</option>
                                            }
                                        }
                                        <option value="add">Add Skipper</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateBoatOperator"></p>
                            </section>
                            <section class="col col-xs-1 col-sm-1 col-md-1 col-lg-1">
                                <i id="elem" href="#"
                                   class="fa fa-question-circle cgpopover"
                                   data-bs-placement="bottom"
                                   data-bs-container="body"
                                   data-bs-toggle="popover"
                                   data-bs-content="Please enter the details for the primary skipper of the vessel"></i>
                            </section>
                            <div id="RegistrationSection" class="col-xs-12 col-sm-6 col-md-6 col-lg-6" style="display:none;">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10">
                                    <label class="label required col-12">Personal Watercraft Registration Area</label>
                                    <label class="input form-group col-12">
                                        <select class="form-control b form-select" id="VesselArea" name="VesselArea" title="" required>
                                            <option selected="selected" value="">-- Select --</option>
                                            <option value="Auckland">Auckland</option>
                                            <option value="Bay Of Plenty">Bay Of Plenty</option>
                                            <option value="Gisborne">Gisborne</option>
                                            <option id="Hawke's Bay">Hawke's Bay</option>
                                            <option value="Manawatu-Wanganui">Manawatu-Wanganui</option>
                                            <option value="NorthLand">Northland</option>
                                            <option value="Taranaki">Taranaki</option>
                                            <option value="Waikato">Waikato</option>
                                            <option id="Wellington">Wellington</option>
                                            <option value="Canterbury">Canterbury</option>
                                            <option value="Central Otag">Central Otago</option>
                                            <option value="Grey">Grey</option>
                                            <option id="Marlborough">Marlborough</option>
                                            <option value="Nelson">Nelson</option>
                                            <option value="Otago">Otago</option>
                                            <option value="Queenstown Lakes">Queenstown Lakes</option>
                                            <option id="Southland">Southland</option>
                                            <option value="Tasman">Tasman</option>
                                            <option value="West Coast">West Coast</option>
                                        </select>
                                    </label>
                                    <p class="validationContainer" id="validateVesselArea"></p>
                                </section>
                                <section class="col col-sm-2 col-md-2 col-lg-2"></section>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6" id="aucklandRegoSection" style="display:none;">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10">
                                    <label class="label col-12">Personal Watercraft (PWC) Registration</label>
                                    <label class="input form-group col-12">
                                        <input class="form-control b" data-type="TEXTBOX" data-name="AucklandRegistration" id="AucklandRegistration" name="AucklandRegistration" placeholder="Personal Watercraft (PWC) Registration" value="">
                                    </label>
                                    <p class="validationContainer" id="validateAucklandRegistration"></p>
                                </section>
                                <section class="col col-xs-2 col-sm-2 col-md-2 col-lg-2">
                                    <i id="elem" href="#"
                                        class="fa fa-question-circle cgpopover"
                                        data-bs-placement="bottom"
                                        data-bs-container="body"
                                        data-bs-html="true"
                                        data-bs-toggle="popover"
                                        data-bs-content="Registration of PWC including JetSki is required- for more information <a href='https://www.maritimenz.govt.nz/recreational/safety/regional-safety.asp' target='_blank' style='color:blue' title=''> click here </a> "></i>
                                </section>
                            </div>
                            <!--hr class="boatAccordianHairline" /-->
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Is the vessel Professionally built?</label>
                                <label class="input form-group col-12">
                                    <select class="form-control b form-select" id="BuiltProfessionally" name="BuiltProfessionally" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="True">Yes</option>
                                        <option value="False">No</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateBuiltProfessionally"></p>
                            </section>
                            <section class="col col-xs-1 col-sm-1 col-md-1 col-lg-1">
                                <i id="elem" href="#"
                                    class="fa fa-question-circle cgpopover"
                                    data-bs-placement="bottom"
                                    data-bs-container="body"
                                    data-bs-toggle="popover"
                                    data-bs-content="Professionally built is defined as having been primarily constructed by a person or persons professionally engaged in the construction of watercraft"></i>
                            </section>
                            <section class="col col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Vessel Year of Manufacture</label>
                                <label class="input form-group col-12">
                                    <i></i>
                                    <input class="form-control b" data-type="TEXTBOX" data-name="YearOfManufacture" id="YearOfManufacture" name="YearOfManufacture" placeholder="Vessel Year of Manufacture" value="" required>
                                </label>
                                <p class="validationContainer" id="validateYearOfManufacture"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Vessel Make</label>
                                <label class="input form-group col-12">
                                    <i></i>
                                    <input class="form-control b" data-type="TEXTBOX" data-name="BoatMake" id="BoatMake" name="BoatMake" placeholder="Vessel Make" value="" required>
                                </label>
                                <p class="validationContainer" id="validateBoatMake"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required form-group col-12">Vessel Model</label>
                                <label class="input form-group col-12">
                                    <i></i>
                                    <input class="form-control b" data-type="TEXTBOX" data-name="BoatModel" id="BoatModel" name="BoatModel" placeholder="Vessel Model" value="" required>
                                </label>
                                <p class="validationContainer" id="validateBoatModel"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5" id="HullConstructSection">
                                <label class="label required col-12">Construction Type</label>
                                <label class="input form-group col-12">
                                    <select onchange="hideShowHullConstructionOther()" class="form-control b form-select" id="HullConstruction" name="HullConstruction" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="Aluminium">Aluminium</option>
                                        <option value="Steel">Steel</option>
                                        <option value="Fibreglass">Fibreglass</option>
                                        <option value="Carbon">Carbon fibre</option>
                                        <option id="HullConstructionRigidHi" value="RigidHI">Rigid Hull Inflatable</option>
                                        <option id="HullConstructionWood" value="Wood">Wood/ timber</option>
                                        <option id="HullConstructionCement" value="Cement">Ferro cement/ cement</option>
                                        <option id="HullConstructionOther" value="Other">Other</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateHullConstruction"></p>
                            </section>
                            <section class="col col-xs-1 col-sm-1 col-md-1 col-lg-1">
                                <b id="elem" href="#"
                                   class="fa fa-question-circle cgpopover"
                                   data-bs-placement="bottom"
                                   data-bs-container="body"
                                   data-bs-toggle="popover"
                                   data-bs-content="please select the primary construction material of the hull of your vessel"></b>
                            </section>
                            <div class="hidden col-sm-6 col-md-6 col-lg-6" id="HullConstructOtherSection">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10 ">
                                    <label class="label required col-12">Other Construction Type</label>
                                    <label class="input col-12">
                                        <i></i>
                                        <input class="form-control b form-group" type="text" data-type="TEXTBOX" data-name="otherhullconstruction" id="OtherConstructionType" name="otherhullconstruction" placeholder="Other Construction Type" required>
                                    </label>
                                    <p class="validationContainer" id="validateHullConstructOtherSection"></p>
                                </section>
                                <section class="col col-sm-2 col-md-2 col-lg-2"></section>
                            </div>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5" id="HullConfigSection">
                                <label class="label required col-12">Hull Configuration</label>
                                <label class="input form-group col-12">
                                    <select onchange="hideShowHullConfigurationOther()" class="form-control b form-select" id="HullConfiguration" name="HullConfiguration" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="Mono">Mono</option>
                                        <option id="HullConfigurationCatamaran" value="Catamaran">Catamaran</option>
                                        <option id="HullConfigurationTrimaran" value="Trimaran">Trimaran</option>
                                        <option id="HullConfigurationOther" value="Other">Other</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateHullConfiguration"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <div class="hidden col-sm-6 col-md-6 col-lg-6" id="HullConfigurationOtherSection">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10">
                                    <label class="label required col-12">Other Hull Configuration</label>
                                    <label class="input col-12">
                                        <input class="form-control b form-group" type="text" data-type="TEXTBOX" data-name="OtherHullConfiguration" id="OtherHullConfiguration" name="OtherHullConfiguration" placeholder="Other Hull Configuration" value="" required>
                                    </label>
                                    <p class="validationContainer" id="validateOtherHullConfiguration"></p>
                                </section>
                                <section class="col col-sm-2 col-md-2 col-lg-2"></section>
                            </div>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">Motor Type</label>
                                <label class="input form-group col-12">
                                    <select onchange="updateExcess()" class="form-control b form-select" id="MotorType" name="MotorType" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option id="MotorTypeInboardPetrol" value="InboardPetrol">Inboard – Petrol</option>
                                        <option id="MotorTypeInboardDiesel" value="InboardDiesel">Inboard – Diesel</option>
                                        <option id="MotorTypeInboardOther" value="InboardOther">Inboard – Other</option>
                                        <option id="MotorTypeOutboard" value="Outboard">Outboard</option>
                                        <option value="Jet">Jet</option>
                                        <option id="MotorTypeJetskiJet" value="Jetskijet">Jetski Jet</option>
                                        <option id="MotorTypeNA" value="NA">N/A</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateMotorType"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5" id="ModifiedMotorSection">
                                <label class="label required col-12">Has the motor been modified?</label>
                                <label class="input form-group col-12">
                                    <select class="form-control b form-select" id="ModifiedMotor" name="ModifiedMotor" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="True">Yes</option>
                                        <option value="False">No</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateModifiedMotor"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">What is the maximum rated speed of the vessel?</label>
                                <label class="input form-group col-12">
                                    <select class="form-control b form-select" id="MaxRatedSpeed" name="MaxRatedSpeed" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="Upto20Knots">Up to 20 Knots</option>
                                        <option value="Between20and60Knots">Between 20 and 60 Knots</option>
                                        <option value="Over60Knots">Over 60 Knots</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateMaxRatedSpeed"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <!--hr class="boatAccordianHairline" /-->
                            <div class="col-sm-6 col-md-6 col-lg-6" id="RiggingTypeSection">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10">
                                    <label class="label required col-12">Rigging Type</label>
                                    <label class="input form-group col-12">
                                        <select class="form-control b form-select" id="RiggingType" name="RiggingType" required>
                                            <option selected="selected" value="">-- Select --</option>
                                            <option value="StainlessSteelWire">Stainless Steel Wire</option>
                                            <option value="Rod">Rod</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </label>
                                    <p class="validationContainer" id="validateRiggingType"></p>
                                </section>
                                <section class="col col-sm-2 col-md-2 col-lg-2"></section>
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6 d-flex" id="MastTypeSection">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10">
                                    <label class="label required col-12">Mast Type</label>
                                    <label class="input form-group col-12">
                                        <select class="form-control b form-select" id="MastType" name="MastType" required>
                                            <option selected="selected" value="">-- Select --</option>
                                            <option value="Aluminium">Aluminium</option>
                                            <option value="Steel">Steel</option>
                                            <option value="Wooden">Wooden</option>
                                            <option value="CarbonFibre">Carbon Fibre</option>
                                            <option value="Other">Other</option>
                                        </select>
                                    </label>
                                    <p class="validationContainer" id="validateMastType"></p>
                                </section>
                                <section class="col col-xs-2 col-sm-2 col-md-2 col-lg-2">
                                    <i id="elem" href="#"
                                       style="margin-left: 2em;"
                                        class="fa fa-question-circle cgpopover"
                                        data-bs-placement="bottom"
                                        data-bs-container="body"
                                        data-bs-toggle="popover"
                                        data-bs-content="please select the primary construction material of the mast of your vessel"></i>
                                </section>
                            </div>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">$ Vessel Insured Value (Please exclude trailer value)</label>
                                <label class="input form-group col-12">
                                    <input onchange="updateExcess()" class="form-control b" pattern="^\$\d{1,3}(,\d{3})*(\.\d+)?$" data-type="currency" data-name="MaxSumInsured" id="MaxSumInsured" name="MaxSumInsured" placeholder="$ Vessel Insured Value" value="" required>
                                </label>
                                <p class="validationContainer" id="validateMaxSumInsured"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5">
                                <label class="label required col-12">$ Excess</label>
                                <label class="input form-group col-12">
                                    <select class="form-control b form-select" id="excess" name="BoatQuoteExcessOption" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option id="excess250" value="250">$250</option>
                                        <option id="excess500" value="500">$500</option>
                                        <option id="excess1000" value="1000">$1,000</option>
                                        <option id="excess2000" value="2000">$2,000</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateexcess"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <!--hr class="boatAccordianHairline" /-->
                            <section class="col col-xs-12 col-sm-5 col-md-5 col-lg-5" id="VesselTrailer">
                                <label class="label required col-12">Does this Vessel have a Trailer?</label>
                                <label class="input form-group col-12">
                                    <select onchange="hasTrailer()" class="form-control b form-select" id="BoatIsTrailered" name="BoatIsTrailered" required>
                                        <option selected="selected" value="">-- Select --</option>
                                        <option value="True">Yes</option>
                                        <option value="False">No</option>
                                    </select>
                                </label>
                                <p class="validationContainer" id="validateBoatIsTrailered"></p>
                            </section>
                            <section class="col col-sm-1 col-md-1 col-lg-1"></section>
                            <div class="col-sm-6 col-md-6 col-lg-6" id="SelectTrailerSection" style="display:none">
                                <section class="col col-xs-12 col-sm-10 col-md-10 col-lg-10">
                                    <label class="label required col-12">Vessel Trailer</label>
                                    <label class="input form-group col-12">
                                        <select onchange="addNewTrailer()" class="form-control b form-select" id="BoatTrailer" name="BoatTrailer" required>
