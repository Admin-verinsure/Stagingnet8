            $.ajax({
                url: '@Url.Action("GetOrganisationDetails", "Authorize")', // Adjust URL as needed
                type: "POST",
                contentType: "application/json",
                data: postData
            })
                .done(function (response) {
                    // Clear existing dynamic fields
                    $('#dynamicOrgUserTypes').empty();

                    // For each organisation, create a new select input for role and a checkbox for main organization
                    response.forEach(org => {
                        var contentHtml = '<div class="form-group col-12">' +
                            '<label for="UserType_' + org.organisationId + '">User Type for ' + org.name + '</label>' +
                            '<select class="form-control" id="UserType_' + org.organisationId + '">';

                        if (org.roles && Array.isArray(org.roles)) {
                            org.roles.forEach(role => {
                                contentHtml += '<option value="' + role + '">' + role + '</option>';
                            });
                        }

                        contentHtml += '</select>';

                        // Adding checkbox for selecting main organization
                        contentHtml += '<div class="form-check">' +
                            '<input class="form-check-input" type="checkbox" value="" id="MainOrg_' + org.organisationId + '">' +
                            '<label class="form-check-label" for="MainOrg_' + org.organisationId + '">Main Organization</label>' +
                            '</div></div>';

                        $('#dynamicOrgUserTypes').append(contentHtml);
                    });

                    // Logic to ensure only one checkbox can be selected as Main Organization
                    $('.form-check-input').on('change', function () {
                        $('.form-check-input').not(this).prop('checked', false);
                    });
                })
                .fail(function (jqXHR, textStatus, errorThrown) {
                    var errorMsg = jqXHR.responseJSON && jqXHR.responseJSON.error ? jqXHR.responseJSON.error : "Unknown error occurred";
                    alert("Error: " + errorMsg);
                });
        }



