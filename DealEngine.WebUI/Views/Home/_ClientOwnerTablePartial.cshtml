@model DealEngine.WebUI.Models.ProgrammeItem

@if (null != Model.UpcomingDeals)
{
<div class="card-header text-white w3-panel w3-pale-blue w3-border" style="background-color:#3276b1">
    <h6> <i class="fa fa-comments"></i> Upcoming Deals </h6>
</div>
<div class="table-responsive">
    <table id="tableProgItemsUpcoming"
           class="table table-striped" width="100%"
           data-pagination="true"
           data-search="true"
           data-show-jump-to="true"
           data-page-list="[10, 25, 50, 100, 200, All]"
           data-smart-display="false"
           data-toggle="table"
           data-show-columns-search="true"
           data-show-columns-toggle-all="true"
           data-visible-search="true">

        <thead>
         
            <tr>
                <th data-field="name" data-sortable="true">Client Name</th>
                <th data-sortable="false"></th>
            </tr>
        </thead>
        <tbody>

            @if (null != Model.UpcomingDeals)
            {

                @foreach (var item in Model.UpcomingDeals)
                {
                    <tr>
                        <td>@item.OwnerName </td>

                        <td>
                            <div class="btn-group btn-secondary" role="group" aria-label="Basic example">
                                <a class="btn btn-primary btn-sm" href="/Home/ViewClientProgramme?ownerid=@item.OwnerId&programmeid=@item.ProgrammeId"><i class="fa fa-search"></i> View</a>
                            </div>
                        </td>
                    </tr>
                }
            }

        </tbody>
    </table>

</div>

}
<div class="card-header text-white" style="background-color:#3276b1">
    <h6> <i class="fa fa-comments"></i> Deals </h6>
</div>
<div class="table-responsive">
<table id="tableProgrammeItems"
       class="table table-striped" width="100%"
       data-pagination="true"
       data-search="true"
       data-show-jump-to="true"
       data-page-list="[10, 25, 50, 100, 200, All]"
       data-smart-display="false"
       data-toggle="table"
       data-show-columns-search="true"
       data-show-columns-toggle-all="true"
       data-visible-search="true">

    <thead>
        <tr>
            <th data-field="name" data-sortable="true">Client Name</th>
            <th data-sortable="false"></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OwnerDeals)
        {
            <tr>
                <td>@item.OwnerName </td>
                <td>
                        <div class="btn-group btn-secondary" role="group" aria-label="Basic example">
                            <a class="btn btn-primary btn-sm" href="/Home/ClientProgrammeCloning?ownerid=@item.OwnerId&programmeid=@item.ProgrammeId"><i class="fa fa-search"></i> View</a>
                        </div>

                      @*  @if (!item.IsOwnerneedcloning)
                        {
                            <div class="btn-group btn-secondary" role="group" aria-label="Basic example">
                                <a class="btn btn-primary btn-sm" href="/Home/ViewClientProgramme?ownerid=@item.OwnerId&programmeid=@item.ProgrammeId"><i class="fa fa-search"></i> View</a>
                            </div>
                        }
                        else
                        {
                            <div class="btn-group btn-secondary" role="group" aria-label="Basic example">
                                <a class="btn btn-primary btn-sm" href="/Home/ClientProgrammeCloning?ownerid=@item.OwnerId&programmeid=@item.ProgrammeId"><i class="fa fa-search"></i> View</a>
                            </div>
                        }*@

                </td>
            </tr>
        }
    </tbody>
</table>

</div>
