@model DealEngine.WebUI.Models.InformationViewModel

@{ ViewData["Title"] = "Upload Documents"; }


<div id="RotaryDocUpload" class="container">
    <!-- Bread crumb is created dynamically -->
    <!-- row -->
    <div class="form-group row">
        <strong>
            Please upload your Constitution or Trust Deed
            for each Named Party by selecting the Named Party from
            your list of named parties.
            Please then upload the relevant document for that
            Named Party ensuring you have added the Effective Date.
            If a further party needs to be added to
            complete this you can go back and add
            named parties at any time
        </strong>

    </div>

    <div class="col-sm-12" style="overflow-y:auto; height:44vh; width:100%;text-align:center;">
        <form id="DocUploadForm" enctype="multipart/form-data" asp-controller="Information" asp-action="Upload" method="post" class="mt-3">


            @Html.HiddenFor(m => m.ClientProgrammeId)
            <div class="form-group row">
                <label class="col-sm-2 col-form-label">Select Named Party for Document Upload.</label>
                <div class="col-sm-10">
                    <select asp-for="DocumentOrganisation" class="form-control" required>
                        <option onchange="refreshdoclist();" value="select">---Select---</option>
                        @foreach (var option in Model.OrganisationViewModel.Organisations.Where(org => org.Removed==false))
                        {
                            <option value="@option.Name">@option.Name</option>
                        }
                    </select>
                </div>
            </div>


            <div class="form-group row">
                <label asp-for="Name" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                    <input class="form-control" name="DocumentName" placeholder="club constitution or club trust document name">
                    <span name="DocumentName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label class="col-sm-2 col-form-label required">Document Date:</label>
                <div class="col col-xs-12 col-sm-6 col-md-6 col-lg-6">
                    <input type="text" id="DocEffectiveDate" name="DocEffectiveDate" class="form-control" placeholder="Please select Effective Date for this Document" required />
                    <span name="DocEffectiveDate" class="text-danger"></span>
                </div>
                <div class="col col-xs-12 col-sm-1 col-md-1 col-lg-1">
                    <i id="elem" href="#"
                       class="fa fa-question-circle cgpopover"
                       data-bs-placement="bottom"
                       data-bs-container="body"
                       data-bs-html="true"
                       data-bs-toggle="popover"
                       data-bs-content="This date can be either the date signed or approved or submitted if filed with Government"></i>

                </div>
                <span asp-validation-for="DocEffectiveDate" class="text-danger"></span>
            </div>

            <div class="form-group row">
                <label class="col-sm-2 col-form-label">File</label>
                <div class="col-sm-10">
                    <div class="custom-file">
                        <input asp-for="File" class="form-control custom-file-input" name="File" id="fileUploaddoc" />

                    </div>
                </div>
                <div class="col-sm-12 mt-3" style="text-align:center;">
                    <p style="margin:0px !important">Please note: Only .pdf. .doc, .docx, odt and .gdoc file types are accepted.</p>
                </div>

            </div>

            <div asp-validation-summary="All" class="text-danger"></div>

            <button id="" onclick="" type="submit" class="btn btn-primary">Upload File</button>
            <br /><br />
            <br />

        </form>


        <br /><br />

        <!-- row -->


        <div>
            @if (Model.ClientInformationSheet.documents.Where(doc => doc.DeletedBy == null).Count() > 0)
            {
                <div class="form-group row">
                    <div class="col-sm-2 col-md-2">
                    </div>
                    <div class="col-sm-2 col-md-2">
                        <label><strong>Available Documents</strong></label>
                    </div>
                    <div class="col-sm-4 col-md-4">

                    </div>

                    <div class="col-sm-2 col-md-2">

                    </div>

                </div>
            }


            @foreach (var doc in Model.ClientInformationSheet.documents.Where(doc => doc.DeletedBy == null))
            {
                <div class="form-group row" id="@doc.Name">
                    <div class="col-sm-2 col-md-2">
                    </div>
                    <label class="col-sm-2 col-md-2 col-form-label">@doc.OwnerOrganisationName</label>
                    <div class="col-sm-2 col-md-2">
                        @*<a class="btn btn-primary btn-sm" href="/File/GetDocument?id=@doc.Id&format=@doc.Extension"> @doc.Name </a>*@
                        @*<a class="btn btn-primary btn-sm" href="@doc.Path" aria-hidden="true" style="color:white">
                            @doc.Name
                        </a>*@
                        @*<button url="File/GetuploadedDoc">down load me</button>*@
                    <a href="@Url.Action("GetuploadedDoc", "File", new { path = @doc.Path, ContentType = @doc.ContentType, filename = @doc.Name})" class="btn  btn-primary btn-sm"><i class="fa fa-edit"></i>  @doc.Name </a>

                        @*<a class="btn btn-primary btn-xs" style="color:white; font-size:10pt; border:0;" href="/File/GetuploadedDoc/(@doc.path)?format=@doc.ContentType"><i class="fa fa-download"></i> Get PDF</a>*@

                    </div>
                    <label class="col-sm-2 col-md-2 col-form-label">@doc.DocEffectiveDate</label>
                    <div class="col-sm-1 col-md-1">
                        <button class="btn btn-danger rounded-0" value="@doc.Id" onclick="deletedoc('@doc.Id','@doc.Name')"><i class="fa fa-trash"></i></button>

                    </div>

                </div>
            }

        </div>
    </div>


</div>



@section pagespecific {

    <script type="text/javascript">
       
        $(document).ready(function () {
            debugger;

            var $form = $("#DocUploadForm");
            $form.submit(function () {
                $.post($(this).attr('action'), $(this).serialize(), function (response) {
                    // do something here on success
                    debugger;
                    location.reload();
                    $("[id='Document uploads']").trigger("click");
                }, 'json');
                return false;
            });

            
            function refreshdoclist() {
                location.reload();
                $("[id='Document uploads']").trigger("click");
            }

            
        });
    </script>
}
