@model DealEngine.WebUI.Models.Authorization.AuthorizeViewModel

<form>

    <!-- Title -->
    <div class="form-group col-12">
        <h3>Add New Claim</h3>
    </div>

    <!-- Role Name -->
    <div class="form-group col-12">
        <label for="InputClaimName">New Claim Name</label>
        <input type="text" class="form-control" id="newClaimName">
    </div>

    <!-- Save Button -->
    <div class="form-group col-12 p-2">
        <button type="button" class="btn btn-primary btn-lg" onclick="SaveClaim()">Add Claim</button>
    </div>

</form>


