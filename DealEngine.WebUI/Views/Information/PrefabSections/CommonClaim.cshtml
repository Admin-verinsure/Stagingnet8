<div id="Claimtabs">
    <input id="ClaimId" name="ClaimId" type="hidden" form="ClaimNotifications" />
    <input id="OrganisationId" name="OrganisationId" type="hidden" form="ClaimNotifications" />

    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item" id="tab1">
            <a class="nav-link active" href="#clTabs1" data-bs-toggle="tab" onclick="ResetForm('clTabs3','clTabs2', 'ClaimNotification', 'AddupdateBoat', 'AddClearBoat')"> List All </a>
        </li>
        <li class="nav-item" id="tab2">
            <a class="nav-link" href="#clTabs2" data-bs-toggle="tab"> Edit </a>
        </li>
        <li class="nav-item" id="tab3">
            <a class="nav-link" href="#clTabs3" data-bs-toggle="tab" onclick="ResetForm('clTabs3','clTabs2', 'ClaimNotification', 'AddupdateBoat', 'AddClearBoat')"> Add </a>
        </li>
        <li class="nav-item" id="tab4">
            <a class="nav-link" href="#clTabs4" data-bs-toggle="tab"> List Removed </a>
        </li>

    </ul>
    <div class="tab-content">
        <div id="clTabs1" class="tab-pane" role="tabpanel">
            <table id="tblLocation"
                   class="table table-striped" width="100%"
                   data-show-columns="true"
                   data-pagination="true"
                   data-search="true"
                   data-show-jump-to="true">
                <thead>
                    <tr>
                        <th data-field="editButton" data-sortable="false"></th>
                        <th data-field="claimTitle" data-sortable="true">ClaimTitle</th>
                        <th data-field="claimDescription" data-sortable="true">Claim Description</th>
                        <th data-field="claimReference" data-sortable="true">Claim Reference</th>
                        <th data-field="nameofClaimant" data-sortable="true">Name of Claimant</th>
                        <th data-field="deleteButton" data-sortable="false"></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var claim in Model.ClientInformationSheet.ClaimNotifications.Where(l => l.Removed == false).ToList())
                    {
                        <tr id="@claim.Id">
                            <td>
                                <button class="btn btn-success btn-sm" onclick="EditClaim('@claim.Id', '@claim.ClaimTitle')"><i class="fa fa-edit"></i> Edit</button>
                            </td>
                            <td>
                                @claim.ClaimTitle
                            </td>
                            <td>
                                @claim.ClaimDescription
                            </td>
                            <td>
                                @claim.ClaimReference
                            </td>
                            <td>
                                @claim.Claimant
                            </td>
                            <td>
                                <button onclick="SetClaimRemovedStatus('@claim.Id')" type="button" class=" btn btn-danger btn-sm" id="trash"><span class="fa fa-trash"></span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div id="clTabs2" class="tab-pane" role="tabpanel">
            <div class="form-group">
                <label>Select a Location from the 'List All' Tab and Click Edit Button</label>
            </div>

        </div>
        <div id="clTabs3" class="tab-pane" role="tabpanel">

            <form class="" id="ClaimNotifications">
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="ClaimTitle form-label" class="label required">
                                Claim Title:
                            </label>
                        </div>
                        <div class="col-6">
                            @Html.TextBoxFor(m => m.ClientInformationSheet.ClaimNotifications, new { id = "ClaimTitle", @class = "form-control", @onchange = "OnChange(this.id, this.name)", @required = "", @form = "ClaimNotifications" })
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="ClaimDescription form-label" class="label required">
                                ?? text area Claim Description:
                            </label>
                        </div>
                        <div class="col-6">
                            @Html.TextBoxFor(m => m.ClientInformationSheet.ClaimNotifications, new { id = "ClaimDescription", @class = "form-control", @onchange = "OnChange(this.id, this.name)", @required = "", @form = "ClaimNotifications" })
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="ClaimStatus" class="label required form-label">
                                Claim Status
                            </label>
                        </div>
                        <div class="col-6">
                            @*@Html.DropDownListFor(m => m.ClientInformationSheet.ClaimNotifications, Model.ClientInformationSheet.ClaimNotifications, new { id = "ClaimStatus", @class = "custom-select form-select", @onchange = "OnChange(this.id, this.name)", @required = "", @form = "ClaimNotifications" })*@
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="ClaimReference" class="label required form-label">
                                Claim Reference
                            </label>
                        </div>
                        <div class="col-6">
                            @Html.TextBoxFor(m => m.ClientInformationSheet.ClaimNotifications, new { id = "ClaimReference", @class = "form-control", @onchange = "OnChange(this.id, this.name)", @required = "", @form = "ClaimNotifications" })
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="ClaimPolicyReference" class="label form-label">
                                Policy Reference
                            </label>
                        </div>
                        <div class="col-6">
                            @Html.TextBoxFor(m => m.ClientInformationSheet.ClaimNotifications, new { id = "ClaimPolicyReference", @class = "form-control", @onchange = "OnChange(this.id, this.name)", @form = "ClaimNotifications" })
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="postcodedetails" class="label form-label">
                                Policy Insurer Name
                            </label>
                        </div>
                        <div class="col-6">
                            @Html.TextBoxFor(m => m.LocationViewModel.Postcode, new { id = "postcodedetails", @class = "form-control", @onchange = "OnChange(this.id, this.name)", @form = "ClaimNotifications" })
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <div class="row">
                        <div class="col-6">
                            <label for="ClaimInsuredName" class="label form-label">
                                Policy Insured Name
                            </label>
                        </div>
                        <div class="col-6">
                            @Html.TextBoxFor(m => m.LocationViewModel.CommonName, new { id = "ClaimInsuredName", @class = "form-control", @onchange = "OnChange(this.id, this.name)", @form = "ClaimNotifications" })
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <button class="btn btn-sm btn-success text-light" id="AddupdateBoat" onclick="ValidateAddClaim()" form="ClaimNotifications"> Add </button>
                    <button class="btn btn-sm btn-danger text-light" id="AddClearBoat" onclick="ClearBoats('ClaimNotifications','clTabs1')" form="ClaimNotifications"> Clear and Cancel </button>
                </div>
            </form>






            <fieldset id="fieldset">
                <input id="ClaimId" name="ClaimId" type="hidden" />
