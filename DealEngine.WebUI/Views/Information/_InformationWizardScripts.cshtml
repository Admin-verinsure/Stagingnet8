    function DefaultDateRestore() {
        debugger;
        if (document.getElementById("dateselected") != null) {
            var ds = document.getElementById("dateselected").value;
            var ds2 = "";
            var date = new Date();
            var day = ("0" + date.getDate()).slice(-2);
            var month = ("0" + (date.getMonth() + 1)).slice(-2);
            var year = date.getFullYear();
            var currentdate = year + "-" + month + "-" + day;
            if (ds == null) {
                ds = year + "-" + month + "-" + day;
                ds2 = ds;
            }
            else {
                ds2 = year + "-" + month + "-" + day; // This is for when you just want the Default Date not to set with Policy Effective Date
            }
            if (document.getElementById("AddBoatEffectiveDate") != null) {
                document.getElementById("AddBoatEffectiveDate").value = ds;
            }
            if (document.getElementById("BoatEffectiveDate") != null) {
                document.getElementById("BoatEffectiveDate").value = ds;
