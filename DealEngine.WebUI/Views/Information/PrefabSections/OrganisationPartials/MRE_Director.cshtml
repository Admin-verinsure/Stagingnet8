@model DealEngine.WebUI.Models.InformationViewModel

<div class="RealEstateDirectorUnit" style="display:none">

    <div class="form-group row">
        <div class="form-group col-md-6">
            <div class="form-group">
                @Html.LabelFor(m => m.OrganisationViewModel.MREDirectorUnit.Name, new { @class = "label required" })
                @Html.TextBoxFor(m => m.OrganisationViewModel.MREDirectorUnit.Name, new { @class = "form-control", @id = "MREDirectorUnit.Name", @required = "", @maxlength = "250" })
            </div>
        </div>
        <div class="form-group col-md-6">
            <div class="form-group">
                @Html.LabelFor(m => m.OrganisationViewModel.MREDirectorUnit.Qualification, new { @class = "label required" })
                @Html.TextBoxFor(m => m.OrganisationViewModel.MREDirectorUnit.Qualification, new { @class = "form-control", @id = "MREDirectorUnit.Qualification", @required = "", @maxlength = "250" })
            </div>
        </div>
        <div class="form-group col-md-6">
            <div class="form-group">
                @Html.LabelFor(m => m.OrganisationViewModel.MREDirectorUnit.FirmYears, new { @class = "label required" })
                @Html.TextBoxFor(m => m.OrganisationViewModel.MREDirectorUnit.FirmYears, new { @class = "form-control", @id = "MREDirectorUnit.FirmYears", @required = "", @maxlength = "250" })
            </div>
        </div>

        <div class="form-group col-md-6">
            <div class="form-group">
                @Html.LabelFor(m => m.OrganisationViewModel.MREDirectorUnit.ProfessionYears, new { @class = "label required" })
                @Html.TextBoxFor(m => m.OrganisationViewModel.MREDirectorUnit.ProfessionYears, new { @class = "form-control", @id = "MREDirectorUnit.ProfessionYears", @required = "", @maxlength = "250" })
            </div>
        </div>

    </div>
</div>

