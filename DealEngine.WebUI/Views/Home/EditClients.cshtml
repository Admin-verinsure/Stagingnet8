@model EditClientsViewModel

<div class="container">

    <form method="post" action="/Agreement/OdooTaskExtension">
  <button type="submit">Create Odoo Task</button>
</form>



    <form method="POST" action="~/Services/PostClient" novalidate>
        <div class="card">
            <div class="card-header">
                <div class=" form-group">
                    <label>
                        Select Client

                        <select class="b form-select" Id="OrganisationId">
                            <option selected="selected" value="">-- Select --</option>
                            @foreach (var client in Model.Owners)
                            {
                                <option value="@client.Value">@client.Text</option>
                            }
                        </select>
                    </label>
                </div>
                <div class="form-group col-md-6">
                    <button class="btn-success btn btn-xs" type="button" onclick="GetOwner()">Go</button>
                </div>
                @*@if ( Model.Programme.NamedPartyUnitName == "Marsh Real Estate Programme")
                {

                    <div class="form-group col-md-4">
                        <button class="btn-success btn btn-xs" type="button" onclick="GetOwner()">RequestAccount</button>
                    </div>
                }*@
            </div>
            <div class="card-body">
                <div class="form-group">
                    @Html.HiddenFor(Model => Model.Organisation.Id, new { @id = "Organisation.Id" })
                    @Html.HiddenFor(Model => Model.ClientProgramme.Id, new { @id = "ClientProgramme.Id" })
                    @Html.HiddenFor(Model => Model.Programme.Id, new { @id = "Programme.Id" })

                    <div class="form-group col-md-6">

                        <div class="form-group">
                            <label class="label">Name</label>
                            @Html.TextBoxFor(m => m.Organisation.Name, new { @class = "form-control", @id = "Organisation.Name", @required = "" })
                        </div>

                        <div class="form-group">
                            <label class="label">Email</label>
                            @Html.TextBoxFor(m => m.Organisation.Email, new { @class = "form-control", @id = "Organisation.Email", @required = "" })
                        </div>
                        @if (Model.Programme.NamedPartyUnitName == "Apollo Programme" ||
                        Model.Programme.NamedPartyUnitName == "Apollo ML Programme" ||
                        Model.Programme.NamedPartyUnitName == "Apollo Run Off Programme" ||
                        Model.Programme.NamedPartyUnitName == "NZPI Programme")
                        {
                            <div class="form-group">
                                <label class="label">EGlobal Number</label>
                                @Html.TextBoxFor(m => m.ClientProgramme.EGlobalClientNumber, new { @class = "form-control", @id = "ClientProgramme.EGlobalClientNumber", @required = "" })
                            </div>
                        }
                        @if (Model.Programme.NamedPartyUnitName == "Apollo Programme")
                        {

                            <div class="form-group">
                                <label class="label">Tier</label>
                                @Html.DropDownListFor(m => m.ClientProgramme.Tier, Model.Tiers, new { @class = "form-select b", @id = "ClientProgramme.Tier", @required = "", @size = 1 })
                            </div>
                        }
                        @if (Model.Programme.NamedPartyUnitName == "New Zealand Bar Association Liability Programme" ||
                          Model.Programme.NamedPartyUnitName == "Marsh Real Estate Programme")
                        {
                            <div class="form-group">
                                <label class="label">EGlobal Client Branch Code</label><br />
                                @Html.DropDownListFor(m => m.ClientProgramme.EGlobalBranchCode, Model.EGlobalClientBranchCodes, new { @class = "form-control b", @id = "ClientProgramme.EGlobalBranchCode", @required = "", @size = 1 })
                            </div>
                            <div class="form-group">
                                <label class="label">EGlobal Number</label><br />
                                @Html.TextBoxFor(m => m.ClientProgramme.EGlobalClientNumber, new { @class = "form-control", @id = "ClientProgramme.EGlobalClientNumber", @required = "" })
                            </div>
                             <div class="form-group">
                                <label class="label">External Contact Number</label><br />
                                @Html.TextBoxFor(m => m.ClientProgramme.EGlobalExternalContactNumber, new { @class = "form-control", @id = "ClientProgramme.EGlobalExternalContactNumber", @required = "" })
                            </div>
                        }


                        <div class="form-group">
                            <label class="label">Contact Broker</label>
                            @Html.DropDownListFor(m => m.ClientProgramme.BrokerContactId, Model.BrokerContacts, new { @class = "form-select b", @id = "ClientProgramme.BrokerContactId", @required = "", @size = 1 })
                        </div>

                        <label class="label">Insured Address</label><br />
                        <div class="form-group">
                            <label class="label">Street</label><br />
                            @Html.TextBoxFor(m => m.Street, new { @class = "form-control b", @id = "Street", @required = "required", @size = 1 })
                        </div>

                        <div class="form-group">
                            <label class="label">Suburb</label><br />
                            @Html.TextBoxFor(m => m.Suburb, new { @class = "form-control b", @id = "Suburb", @required = "required", @size = 1 })
                        </div>

                        <div class="form-group">
                            <label class="label">City</label><br />
                            @Html.TextBoxFor(m => m.City, new { @class = "form-control b", @id = "City", @required = "required", @size = 1 })
                        </div>

                        <div class="form-group">
                            <label class="label">Postcode</label><br />
                            @Html.TextBoxFor(m => m.Postcode, new { @class = "form-control b", @id = "Postcode", @required = "required", @size = 1 })
                        </div>


                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button class="btn btn-primary btn-xs" type="submit">Update</button>
            </div>
        </div>
    </form>
</div>
<div class="modal overlay" id="loadModal" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">
                <p><img src="/img/loading.gif" /> Loading. Please wait...</p>
            </div>
        </div>
    </div>
</div>
@section pagespecific {
    <script type="text/javascript">
        function GetOwner() {
            debugger;
            var organisationId = document.getElementById('OrganisationId');
            var id = organisationId.options[organisationId.selectedIndex].value;
            var progid = document.getElementById('Programme.Id').value;
            $("#loadModal").show();
              $.ajax({
                type: 'Post',
                url: '@Url.Action("GetClient", "Services")',
                data: { Id: id ,ProgId: progid}
            })
                .done(function (data) {
                    debugger;
                var OutPut = JSON.parse(data);
                PopulateView(OutPut);
                $("#loadModal").hide();         
            })
            .fail(function (jqXhr, textStatus, errorThrown) {
                debugger;
                console.log(errorThrown);
                $("#loadModal").hide();         
            });

            @*$.ajax({
                type: 'Post',
                url: '@Url.Action("GetClient", "Services")',
                data: { Id: id ,ProgId: progid}
            })
                .done(function (Data) {
                    debugger;
                    $("#organisation.name").val('asd');
                    $("#loadModal").hide();  
            })
            .fail(function (jqXhr, textStatus, errorThrown) {
                debugger;                    $("#organisation.name").val('asdasx');

                console.log(errorThrown);
                $("#loadModal").hide();         
            });*@

        }

    </script>

}
