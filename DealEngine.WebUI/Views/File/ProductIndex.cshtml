@model List<DealEngine.Domain.Entities.Product>

    <div id="content" class="container">

        <div class="form-group">
            <h1 class="page-title txt-color-blueDark">
                <!-- PAGE HEADER -->
                <i class="fa-fw fa fa-home"></i>  <span>
                    <a href="~/Home/Index"> Dashboard</a>
                    > My Products
                </span>
            </h1>
        </div>
        <div class="form-group">
            <span>
            <a class="btn btn-primary btn-xs text-white" href="/Programme/TermSheetConfirguration?Id=@ViewBag.ProgrammeId"><i class="fa fa-home"></i> Back </a>
            </span>
        </div>
        <div class="form-group">
            <div class="card">
                <div class="card-header">
                    <span class="widget-icon">
                        <h2><i class="fa fa-comments txt-color-white"></i> Manage Product to attach Document to </h2>
                    </span>
                </div>
                <div class="card-body">
                    @if (Model.Count < 0)
                    {
                        <h2><i class="fa fa-comments txt-color-white"></i> No products attached to Programme </h2>
                    }
                    else
                    {
                        <table class="table table-striped table-hover table-condensed">
                            <tbody>
                                @foreach (var product in Model)
                                {
                                    <tr>
                                        <td>@product.Name</td>
                                        <td>
                                        @if (User.HasClaim("EditManageDocuments", "EditManageDocuments") || User.HasClaim("ViewManageDocuments", "ViewManageDocuments"))
                                            {
@*                                            <a onclick="location.href='@Url.Action("ManageDocuments", "File",new { productId = @product.Id,ProgrammeId=@ViewBag.ProgrammeId})" class="btn btn-primary btn-sm" style="color:white">Rerender Selected document </a>
*@
                                            <a class="btn btn-primary btn-xs" href="https://not4profit.online/helpdesk_ticket">
                                                File HelpDesk Ticket
                                            </a>
@* <a class="btn btn-primary btn-xs"  onclick="location.href='@Url.Action("ManageDocuments", "File",new { productId = @product.Id,ProgrammeId=@ViewBag.ProgrammeId})'" >File HelpDesk Ticket</a>
 *@                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>