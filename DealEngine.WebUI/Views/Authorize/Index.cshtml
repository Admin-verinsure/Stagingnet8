                    alert("Please fill in all required fields for a Broker associated with Marsh.");
                    return;
            }*/

            // Generate username
            var randomNum = Math.floor(Math.random() * 1000);
            var username = firstName.replace(/\s+/g, '') + '_' + lastName.replace(/\s+/g, '') + randomNum;

            var postData = {
                Username: username,
                FirstName: firstName,
                LastName: lastName,
                Email: email,
                HomePhone: homePhone,
                MobilePhone: mobilePhone,
                Organisations: selectedOrgs,
                MainOrganisationId: mainOrgId,
                Roles: uniqueRolesToAdd,
                //UserType: userType,
                OktaUID: oktaUID,
                SalespersonUsername: salespersonUsername,
                EmployeeNumber: employeeNumber,
                Password: password
            };

            $.ajax({
                url: '@Url.Action("CreateUser", "Authorize")', // Adjust URL as needed
                type: "POST",
                data: postData
            })
                .done(function (data) {
                    // Handle success
                    alert("User added successfully!");
                    location.reload();
                })
                .fail(function (jqXHR, textStatus, errorThrown) {
                    var errorMsg = jqXHR.responseJSON && jqXHR.responseJSON.error ? jqXHR.responseJSON.error : "Unknown error occurred";
                    alert("Error: " + errorMsg);
                });
        }


