@model DealEngine.WebUI.Models.InformationViewModel

<form id="PIViewModel" class="is-valid" data-accordianId="Sub Limit">
    <div class="form-group">
        <div class="row">
            <div class="col-6">
                <label for="assettotal" class="label">
                    <strong>Sub-Limits</strong>
                </label>
            </div>
            <div class="col-3">
                <label for="assettotal" class="label">
                    <strong>Limit</strong>
                </label>
            </div>
            <div class="col-3">
                <label for="assettotal" class="label">
                    
