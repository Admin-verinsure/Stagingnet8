@model IssueUISViewModel

<div class="container">
    <form id="ReportForm" method="POST" action="~/Home/GetReportView" novalidate>
        <input type="text" class="form-control" value="@Model.programme.Id" id="programmeId" name="ProgrammeId" hidden>
        <input type="text" class="form-control" value="@Model.programme.Name" id="programmeName" name="ProgrammeName" hidden>
        <input type="text" class="form-control" value="@Model.programme.NamedPartyUnitName" id="programmeNamedPartyUnitName" name="ProgrammeNamedPartyUnitName" hidden>
        <div class="card">
            <div class="card-header">
                <h5>
                    This page lists the reports available for this programme.
                </h5>
            </div>
            <div class="card-body">
                <table class="container">
                    <thead>
                        <tr>
                            <th>
                                Name
                            </th>

                        </tr>
                    </thead>
                    <tbody>
                        <tr>

                            <td>
                                <select class=" b form-select" id="ClientProg" name="queryselect">
                                    <option selected="selected" value="">-- Select --</option>
                                    @foreach (var product in Model.programme.Products)
                                    {
                                        var productcode = @product.UnderwritingModuleCode.Substring(@product.UnderwritingModuleCode.IndexOf("_") + 1);
                                        if (@productcode.IndexOf("_") > 0)
                                        {
                                            <option value=@productcode.Substring(0, @productcode.IndexOf("_"))>@product.Name  Premium report</option>
                                        }
                                        else
                                        {
                                            <option value=@productcode>@product.Name  Premium report</option>

                                        }
                                    }

                                    @{
                                        if (Model.programme.EnableFAPReport)
                                        {
                                            <option value="FAP">FAP Report</option>

                                        }
                                    }
                                    @{
                                        if (Model.programme.EnableRevenueActivity)
                                        {
                                            <option value="RevenueActivity">RevenueActivity Report</option>
                                        }

                                    }
                                    @{
                                        if (Model.programme.EnableDistrictClubReport)
                                        {
                                            <option value="DistrictReport">District Club Status Report</option>

                                        }
                                    }



                                </select>

                                @{
                                    if (Model.programme.EnableDistrictClubReport)
                                    {
                                        <!-- ✅ District Filter (separate) -->
                                        <div class="mt-2" id="districtContainer" style="display:none;">
                                            <select class="form-control" id="DistrictFilter" name="district">
                                                <option value="">-- Select District --</option>
                                                <option value="9910">District 9910</option>
                                                <option value="9920">District 9920</option>
                                                <option value="9930">District 9930</option>
                                                <option value="9940">District 9940</option>
                                            </select>
                                        </div>

                                    }
                                }

                            </td>


                        </tr>

                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <button class="btn btn-primary btn-xs" id="submit" type="submit">View</button>
            </div>
        </div>
    </form>
</div>
<div class="modal overlay" id="AddReportModal" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">
                <p><img src="/img/loading.gif" /> Fetching Records. Please wait...</p>
            </div>
        </div>
    </div>
</div>

<div class="modal overlay" id="RevenueReportModal" tabindex="-1" role="dialog" data-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body">
                <p><img src="/img/loading.gif" /> This report has a large number of columns and is not suitable for viewing on screen.  It will download automatically once generated.</p>
            </div>
        </div>
    </div>
</div>

<script>
      $(function () {

        $("#submit").click(function () {

            var selectedreport = $("#ClientProg").val();

            if (selectedreport === "RevenueActivity") {
                $("#RevenueReportModal").show();
            } else {
                $("#AddReportModal").show();
            }

            $('#ReportForm').submit();

            setTimeout(function () {
                $('#RevenueReportModal').hide();
            }, 40000);
        });

        $("#ClientProg").change(function () {
            if ($(this).val() === "DistrictReport") {
                $("#districtContainer").show();
            } else {
                $("#districtContainer").hide();
            }
        });

        // handle reload case
        if ($("#ClientProg").val() === "DistrictReport") {
            $("#districtContainer").show();
        }

    });
</script>
