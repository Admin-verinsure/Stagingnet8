@model DealEngine.WebUI.Models.UserViewModel
<div class="container">
    <form method="POST" action="~/Admin/PostCreateUser" novalidate id="form">
        @Html.HiddenFor(m=>m.Organisation.Id, new { @id="Organisation.Id"})
        <div class="card">
            <div class="card-header">
                <div class="form-group">
                    @Html.LabelFor(m => m.User.Email)
                    @Html.TextBoxFor(m => m.User.Email, new { @class = "form-control", @id = "User.Email", @required = "", @placeholder = "email" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.User.FirstName)
                    @Html.TextBoxFor(m => m.User.FirstName, new { @class = "form-control ", @id = "User.FirstName" })
                </div>

                <div class="form-group">
                    <label id="IsUserLoggedout"></label>
                </div>
                <div class="form-group" style="display:none" id="resenddiv">
                    <button class="btn-success btn btn-xs" type="button" onclick="ResendLogin()">Resend Login</button>
                </div>

                <div class="form-group" style="display:none" id="unlockdiv">
                    <button class="btn-success btn btn-xs" type="button" onclick="UnlockUser()">Unlock User</button>
                </div>


                <div class="form-group">
                    <button class="btn-success btn btn-xs" type="button" onclick="GetUser()">Search</button>
                </div>
                @*<div class="form-group">
            @Html.LabelFor(m => m.User.FirstName)
            @Html.TextBoxFor(m => m.User.FirstName, new { @class = "form-control", @id = "User.FirstName", @required = "", @placeholder = "FirstName" })
        </div>*@




            </div>
            <div class="card-body">

                <div class="form-group">
                    @Html.LabelFor(m => m.User.LastName)
                    @Html.TextBoxFor(m => m.User.LastName, new { @class = "form-control ", @id = "User.LastName" })
                </div>
                <div class="form-group">
                    @Html.LabelFor(m => m.User.UserName)
                    @Html.TextBoxFor(m => m.User.UserName, new { @class = "form-control ", @id = "User.UserName" })
                </div>


                @*<div class="form-group">
            @Html.LabelFor(m => m.Organisation.IsInsurer)
            @Html.DropDownListFor(m => m.Organisation.IsInsurer, Model.BooleanOptions, new { @class = "b", @id = "Organisation.IsInsurer" })
            @Html.LabelFor(m => m.Organisation.IsTC)
            @Html.DropDownListFor(m => m.User.PrimaryOrganisation.IsTC, Model.BooleanOptions, new { @class = "b", @id = "Organisation.IsTC" })
            @Html.LabelFor(m => m.Organisation.IsBroker)
            @Html.DropDownListFor(m => m.Organisation.IsBroker, Model.BooleanOptions, new { @class = "b", @id = "Organisation.IsBroker" })
        </div>*@
            </div>
            @*<div class="card-footer">
                <button class="btn btn-primary btn-xs" type="submit">Update</button>
            </div>*@
        </div>
    </form>
</div>
@section pagespecific {
    <script type="text/javascript">

        function GetUser() {
            var userEmail = document.getElementById('User.Email').value;
            var userFname = document.getElementById('User.FirstName').value;

            $.ajax({
                type: 'Post',
                url: '@Url.Action("GetCreateUser", "Admin")',
                data: { UserEmail: userEmail, UserFname: userFname }
            })
                .done(function (data ,status, xhr) {
                    debugger;
                    if (data.jsonObj != null) {
                        var OutPut = JSON.parse(data.jsonObj);
                        document.getElementById('IsUserLoggedout').innerHTML = "<span style='color:green'>" + data.isusserLogged+"</span>" ;

                        if (data.isusserLogged == "User never Logged in.") {
                            $("#resenddiv").show();
                        } else {
                            $("#resenddiv").hide();
                        }
                        if (data.isusserLogged == "User has Logged in system once but now logged out") {
                            $("#unlockdiv").show();
                        } else {
                            $("#unlockdiv").hide();
                        }

                        PopulateView(OutPut);
                    } else {
                        document.getElementById("form").reset();
                        document.getElementById("Organisation.Id").value = '@System.Guid.Empty';
                        document.getElementById('User.Email').value = userEmail;
                    }
                })
                .fail(function (jqXhr, textStatus, errorThrown) {
                    debugger;
                    console.log(errorThrown);
                });
        }


        function ResendLogin() {
            var userEmail = document.getElementById('User.Email').value;
            $.ajax({
                type: 'Post',
                url: '@Url.Action("ResendEmail", "Admin")',
                data: { UserEmail: userEmail }
            })
                .done(function (data) {
                    debugger;
                    if (data == true) {
                        document.getElementById('IsUserLoggedout').innerHTML = "<span style='color:green'>User Login Information sent Successfully</span>";
                        $("#resenddiv").hide();
                    }
                })
                .fail(function (jqXhr, textStatus, errorThrown) {
                    debugger;
                    console.log(errorThrown);
                });
        }

        function UnlockUser() {
            var userEmail = document.getElementById('User.Email').value;
            $.ajax({
                type: 'Post',
                url: '@Url.Action("UserUnlock", "Admin")',
                data: { UserEmail: userEmail }
            })
                .done(function (data) {
                    debugger;
                    if (data == true){
                        document.getElementById('IsUserLoggedout').innerHTML = "<span style='color:green'>User Unlocked Successfully</span>";
                        $("#unlockdiv").hide();
                    }

                })
                .fail(function (jqXhr, textStatus, errorThrown) {
                    debugger;
                    console.log(errorThrown);
                });
        }

        
    </script>
}