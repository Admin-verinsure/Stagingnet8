@model DealEngine.WebUI.Models.AdminViewModel

<div class="card">
    <div class="card-header">
        <span class="widget-icon"> <i class="fa fa-desktop text-white"></i> </span>
        <h2> Impersonate User </h2>
    </div>
    <div class="card-body">
        <form action="ImpersonateUser" method="post">
            <div class="form-group">
                <select class="form-select chosen-select" name="username"
                        data-placeholder="Search by first name, last name, Email or username ...">
                    <option value=""></option>
                    @foreach (var user in Model.DomainUsers.OrderBy(u => u.FirstName).ThenBy(u => u.LastName))
                    {
                        var displayName = $"{user.FirstName} {user.LastName}".Trim();
                        if (string.IsNullOrWhiteSpace(displayName))
                        {
                            displayName = user.UserName;
                        }
                        <option value="@user.UserName">@displayName — @user.UserName</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <button class="btn btn-sm btn-success" type="submit">
                    Impersonate User
                </button>
            </div>
        </form>
    </div>
</div>