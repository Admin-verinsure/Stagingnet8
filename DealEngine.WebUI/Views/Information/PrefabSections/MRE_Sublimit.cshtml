<script type="text/javascript">
    if (document.getElementById('sublimitvaluations').value == 0) {
        document.getElementById('sublimitvaluations').value = 250000;
    }
    if (document.getElementById('sublimitbusinesssales').value == 0) {
        document.getElementById('sublimitbusinesssales').value = 1000000;
    }
    if (document.getElementById('sublimitbusinesssalesag').value == 0) {
        document.getElementById('sublimitbusinesssalesag').value = 2000000;
    }
    if (document.getElementById('sublimitruralsales').value == 0) {
        document.getElementById('sublimitruralsales').value = 1000000;
    }
    if (document.getElementById('sublimitruralsalesag').value == 0) {
        document.getElementById('sublimitruralsalesag').value = 2000000;
    }
    if (document.getElementById('sublimitemployeefidelity').value == 0) {
        document.getElementById('sublimitemployeefidelity').value = 250000;
    }
    if (document.getElementById('sublimitlossofdocuments').value == 0) {
        document.getElementById('sublimitlossofdocuments').value = 100000;
    }
    if (document.getElementById('sublimitinvestigationcosts').value == 0) {
        document.getElementById('sublimitinvestigationcosts').value = 250000;
    }
    if (document.getElementById('sublimitpublicrelationsexpenses').value == 0) {
        document.getElementById('sublimitpublicrelationsexpenses').value = 50000;
    }
    if (document.getElementById('sublimitpollutionexclusion').value == 0) {
        document.getElementById('sublimitpollutionexclusion').value = 250000;
    }
    if (document.getElementById('sublimitpunitiveexemplarydamages').value == 0) {
        document.getElementById('sublimitpunitiveexemplarydamages').value = 100000;
    }
</script>