<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        autoReload="true"
        internalLogLevel="Info"
        internalLogFile="/var/log/dealengine/internal-nlog.txt">

    <!-- enable asp.net core layout renderers -->
    <extensions>
      <add assembly="NLog.Web.AspNetCore"/>
    </extensions>

    <!-- the targets to write to -->
	  <targets>

		  <target xsi:type="File"
				  name="debugFile"
				  fileName="/var/log/dealengine/debug-${shortdate}.log"
				  layout="${longdate} ${uppercase:${level}} ${logger} ${message}" />

		  <target xsi:type="File"
				  name="infoFile"
				  fileName="/var/log/dealengine/info-${shortdate}.log"
				  layout="${longdate} ${uppercase:${level}} ${logger} ${message}" />

		  <target xsi:type="File"
				  name="errorFile"
				  fileName="/var/log/dealengine/error-${shortdate}.log"
				  layout="${longdate} ${uppercase:${level}} ${logger} ${message}" />

	  </targets>



	  <!-- rules to map from logger name to target -->
	  <rules>
		  <logger name="TestLogger" minlevel="Debug" writeTo="debugFile" />

		  <!-- NHibernate SQL Logging -->
		  <logger name="NHibernate.Type" minlevel="Trace" writeTo="debugFile" />
		  <logger name="NHibernate.SQL" minlevel="Trace" writeTo="debugFile" />
		  <logger name="NHibernate.*" minlevel="Trace" writeTo="debugFile" />



		  <!-- Your existing generic rules -->
		  <logger name="*" minlevel="Debug" writeTo="debugFile" />
		  <logger name="*" minlevel="Info" writeTo="infoFile" />
		  <logger name="*" minlevel="Error" writeTo="errorFile" />

	  </rules>

  </nlog>
</configuration>