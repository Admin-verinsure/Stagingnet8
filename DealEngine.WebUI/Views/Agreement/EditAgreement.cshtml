@model DealEngine.WebUI.Models.Agreement.ViewAgreementViewModel

<div class="container">
    <div class="row">
        <h1 class="page-title txt-color-blueDark">
            <i class="fa-fw fa fa-home"></i>
            <a href="~/Agreement/ViewAcceptedAgreement/@Model.ClientProgrammeId"> Agreement</a>
            > <span>Edit Agreement</span>
        </h1>
    </div>
    <div class="row">
        <span>
            <a onclick="location.href='@Url.Action("ViewAcceptedAgreement", "Agreement", new { Id = @Model.ClientProgrammeId })'" style="color:dodgerblue;font-size:30px; cursor:pointer"> <span class="icon-append fa fa-arrow-circle-left"></span> </a>
        </span>
    </div>

    <div class="row">
        <div class="jarviswidget container-fluid" id="wid-id-10"
             data="false"
             data-widget-editbutton="false"
             data-widget-togglebutton="false"
             data-widget-deletebutton="false"
             data-widget-custombutton="false"
             data-widget-sortable="false">
            <header>
                <span class="widget-icon"> <i class="fa fa-list-alt"></i> </span>
                <h2>@ViewBag.Title </h2>
            </header>
            <form id="edit-agreement-form-@Model.ClientAgreementId" method="post" action="@Url.Action("EditAgreement", "Agreement")">
                @Html.HiddenFor(m => m.ClientAgreementId)
                @Html.HiddenFor(m => m.InformationSheetId)

                <table class="table table-striped table-bordered">
                    <tbody>
                        <tr>
                            <td>
                                <label class="label"><strong>Policy Start Date: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.EditorFor(model => model.StartDate, new { htmlAttributes = new { @class = "Startdate", dateFormat = "dd/mm/yy" } })
                                </label>
                            </td>
                        </tr>
                        <tr class="table-light">
                            <td>
                                <label class="label"><strong>Policy End Date: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.EditorFor(model => model.EndDate, new { htmlAttributes = new { @class = "Startdate", dateFormat = "dd/mm/yy" } })
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Client Number #: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.ClientNumber)
                                </label>
                            </td>
                        </tr>
                        <tr class="table-light">
                            <td>
                                <label class="label"><strong>Insurer Policy #: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.PolicyNumber)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Brokerage Rate: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.BrokerageRate)
                                </label>
                            </td>
                        </tr>
                        <tr class="table-light">
                            <td>
                                <label class="label"><strong>Administration Fee: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.AdministrationFee)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Retroactive Date: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.RetroactiveDate)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Territory: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.TerritoryLimit)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Jurisdiction: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.Jurisdiction)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Professional Business: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.ProfessionalBusiness)
                                </label>
                            </td>
                        </tr>
                        <tr class="table-light">
                            <td>
                                <label class="label"><strong>Insured Name: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.InsuredName)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <label class="label"><strong>Continuity Date: </strong></label>
                            </td>
                            <td>
                                <label class="input">
                                    @Html.TextBoxFor(m => m.ContinuityDate)
                                </label>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="form-group">
                                    <button type="submit" class="btn btn-success btn-sm"><i class="fa fa-edit"></i> Save</button>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="window.close();"><i class="fa fa-trash"></i> Cancel</button>
                                </div>
                            </td>
                            <td></td>
                        </tr>
                    </tbody>
                </table>
            </form>
        </div>
    </div>
</div>

@section pagespecific {
    <script>
        $(document).ready(function () {
            $('.Startdate').datepicker({
                changeMonth: true,
                changeYear: true,
                dateFormat: "dd/mm/yy"
            });

            $('#edit-agreement-form-@Model.ClientAgreementId').on('submit', function (event) {
                debugger;
                event.preventDefault();
                $.ajax({
                    url: $(this).attr('action'),
                    type: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    data: $(this).serialize(),
                   success: function (data) {
                     // Set a flag in local storage
                    // localStorage.setItem('redirectToViewAgreement', '@Model.ClientAgreementId');
                      //  localStorage.setItem('redirectToViewAgreement', 'testing local storage');
                        localStorage.setItem('reloadParent', 'true');
                     // Close the current window
                     window.close();
                        $("#agreementView").load(url, function () {});
                      },
                    error: function (xhr, status, error) {
                        console.error('Error submitting form:', error);
                    }
                });
            });


            window.onbeforeunload = function () {
                if (window.opener) {
                    window.opener.postMessage('reload', '*');
                }
            };



        });
    </script>
}
