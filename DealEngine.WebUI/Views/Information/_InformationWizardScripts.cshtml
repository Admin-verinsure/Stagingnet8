                document.getElementById("MotorEffectiveDate").value = ds;
            }
            if (document.getElementById("TrailerEffectiveDateModal") != null) {
                document.getElementById("TrailerEffectiveDateModal").value = ds;
            }
            if (document.getElementById("RemoveVehicleCeaseEffectiveDate") != null) {
