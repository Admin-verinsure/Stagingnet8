@model DealEngine.WebUI.Models.InformationViewModel

<form id="CTViewModel" class="is-valid" data-accordianId="Administering your trusts Advisory">

    <label class="label">
        <strong>
            Your Requirements for Extra Covers:
            If you want a quote for covers for please select yes below:
        </strong>
    </label>

    <!-- Button under label -->
    <div class="mt-2 mb-3">
        <button class="btn btn-info" type="button" data-bs-toggle="collapse" data-bs-target="#trustAdvisoryPanel" aria-expanded="false" aria-controls="trustAdvisoryPanel">
            Administering your trusts Advisory
        </button>
    </div>

    <!-- Collapsible panel -->
    <div class="collapse" id="trustAdvisoryPanel">
        <div class="card card-body">
            The covers are provided on the basis of a single Club or District trust being included in the cover provided.
            To be covered:
            1. the trust name must be entered in the named parties section above – you can do that at any time by opening the panel
            2. the trust must be controlled by the Club.  To be controlled the Club must have the power to appoint and remove trustees.
            Additional trusts listed in the named parties will be covered by an extension to the policy.
            Answering No or Not Sure does not stop the trust being covered but will require you to work with the insurance team to ensure cover continues.
        </div>
    </div>

    <div class="form-group mt-3">
        <div class="row">
            <div class="col-9">
                <label class="label required">
                    Has each trust deed been reviewed by the Club in the last 12 months and the trust deed version uploaded is to the best of your knowledge the current operative
                    trust deed date?
                </label>
            </div>
            <div class="col-3">
                <select id="HasClubTrustDeedReviewed" name="CTViewModel.HasClubTrustDeedReviewed" class="form-select" onchange="OnChange(this.id, this.name)" required>
                    @foreach (var option in Model.CTViewModel.HasClubTrustDeedReviewed)
                    {
                        <option selected="@option.Selected" value="@option.Value">@option.Text</option>
                    }
                </select>
            </div>
        </div>
    </div>

</form>
